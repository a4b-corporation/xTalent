/////////////////////////////////////////////////////////////
//  TOTAL REWARD  –  Thin Persistence / Smart Service
//  (uuid = pk mặc định, unless noted)
//  REVISED: 21Nov2025
//  CALCULATION RULES MODULE ADDED: 25Nov2025
/////////////////////////////////////////////////////////////


//***************************************************
// * 0.  Configuration Scope – Multi-Country/LE Scoping
// *     ADDED 26Mar2026: Option 2 (Config Scope Group)
// ***************************************************/

// changed 26Mar2026: NEW - Config Scope Group abstraction for multi-country/LE deployment
// PURPOSE: Phase 2 scoping mechanism. Allows grouping country + LE + BU into named scopes.
// USAGE: Definition tables reference config_scope_id as ALTERNATIVE to inline country_code/legal_entity_id.
// PHASE 1 (Light Touch): Use inline country_code + legal_entity_id directly on definition tables.
// PHASE 2 (Full Scope): Use config_scope_id for complex scope hierarchies (multiple countries/LEs).
// After both phases: client có thể choose inline fields (simple) hoặc scope group (advanced).

Table comp_core.config_scope {
  id              uuid [pk]
  scope_code      varchar(50) [unique, not null]     // VN_DEFAULT, SG_DEFAULT, GLOBAL, VN_TECH_BU
  scope_name      varchar(200) [not null]            // Display name
  scope_type      varchar(20) [not null]             // COUNTRY | LEGAL_ENTITY | BUSINESS_UNIT | HYBRID
  
  country_code    char(2) [null]                     // ISO 3166-1 alpha-2 (VN, SG, US...). NULL = multi-country scope
  legal_entity_id uuid [null]                        // specific LE. NULL = all LEs within country
  business_unit_id uuid [null]                       // specific BU. NULL = all BUs within LE
  
  priority        int [default: 0]                   // higher = more specific. Resolution: max priority wins
  // Priority convention: GLOBAL=0, COUNTRY=10, LE=20, BU=30
  
  parent_scope_id uuid [ref: > comp_core.config_scope.id, null]  // inheritance: BU scope → LE scope → Country scope → Global
  inherit_flag    boolean [default: true]             // true = inherit unset configs from parent scope
  
  description     text [null]
  is_active       boolean [default: true]
  metadata        jsonb [null]
  
  created_at      timestamp [default:`now()`]
  updated_at      timestamp [null]
  
  Indexes {
    (scope_code)
    (scope_type, country_code)
    (country_code, legal_entity_id)
    (parent_scope_id)
    (is_active) [where: "is_active = true"]
  }
  
  Note: '''
    changed 26Mar2026: NEW - Configuration Scope Group (Option 2).
    
    Phased Approach:
    - Phase 1 (Light Touch): Definition tables use inline country_code + legal_entity_id.
      Simple, backward compatible, works for 1-3 countries.
    - Phase 2 (Config Scope Group): Definition tables reference config_scope_id.
      Advanced, supports scope hierarchy + inheritance, works for 5+ countries.
    - Both phases co-exist: config_scope_id takes precedence if populated.
    
    Resolution Order (most specific wins):
      1. config_scope_id (if populated) → resolved scope
      2. Inline country_code + legal_entity_id (if populated)
      3. NULL = global (applies everywhere)
    
    Example Hierarchy:
      GLOBAL (priority=0)
       └─ VN_DEFAULT (priority=10, country_code=VN)
           └─ VN_ENTITY_A (priority=20, legal_entity_id=xxx)
               └─ VN_TECH_BU (priority=30, business_unit_id=yyy)
  '''
}

// changed 26Mar2026: NEW - Bridge table for scopes that span multiple countries/LEs
Table comp_core.config_scope_member {
  id              uuid [pk]
  scope_id        uuid [ref: > comp_core.config_scope.id, not null]
  
  member_type     varchar(20) [not null]             // COUNTRY | LEGAL_ENTITY | BUSINESS_UNIT
  country_code    char(2) [null]                     // populated when member_type = COUNTRY
  legal_entity_id uuid [null]                        // populated when member_type = LEGAL_ENTITY
  business_unit_id uuid [null]                       // populated when member_type = BUSINESS_UNIT
  
  created_at      timestamp [default:`now()`]
  
  Indexes {
    (scope_id, member_type, country_code, legal_entity_id) [unique]
    (country_code)
    (legal_entity_id)
  }
  
  Note: '''
    changed 26Mar2026: NEW - For HYBRID scope types that span multiple countries/LEs.
    Example: APAC scope with members VN, SG, TH, MY.
    For simple single-country scopes, use config_scope.country_code directly.
  '''
}


//***************************************************
// * 1.  Core Compensation – Fixed Pay
// ***************************************************/


Table comp_core.salary_basis {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  frequency       varchar(20)         // HOURLY | MONTHLY | ANNUAL
  currency        char(3)
  allow_components boolean [default:true]
  
  // changed 26Mar2026: Multi-country/LE scoping (Option 1 + 2)
  // PURPOSE: Admin UI filtering / grouping ONLY — does NOT determine which salary_basis
  //          is assigned to an employee. Use eligibility_profile_id for assignment decisions.
  // PHASE 1 (Light Touch): Use these inline fields directly. NULL = global.
  country_code    char(2) [null]                     // changed 26Mar2026: ISO country code. NULL = global (all countries). For UI filtering only.
  legal_entity_id uuid [null]                        // changed 26Mar2026: specific LE. NULL = all LEs. For UI filtering only.
  // PHASE 2 (Config Scope): Use config_scope_id for advanced scope hierarchy.
  // If config_scope_id is populated, it takes precedence over inline fields.
  config_scope_id uuid [ref: > comp_core.config_scope.id, null]  // changed 26Mar2026: Option 2 - scope group reference. For UI filtering only.
  
  // changed 03Apr2026: NEW — Eligibility Central integration.
  // PURPOSE: Defines WHO is eligible for this salary basis.
  //          Evaluated by the centralized eligibility engine (eligibility.eligibility_profile).
  //          domain = 'COMPENSATION' in eligibility_profile.
  //          NULL = globally eligible (all employees are eligible).
  // CRITICAL SEPARATION:
  //   - eligibility_profile_id → DECIDES assignment eligibility (business rule, evaluated by engine)
  //   - country_code / legal_entity_id / config_scope_id → admin UI filter/grouping ONLY
  //   - These two concerns are orthogonal: an employee in VN can be eligible via rule_json,
  //     independent of what country_code is set on this salary_basis.
  // EXPIRY RULE (03Apr2026): When an employee's work_relationship changes scope
  //   (e.g., country transfer → new employment.contract + new work_relationship + new assignment),
  //   eligibility engine re-evaluates. If employee is NO LONGER eligible:
  //   → compensation.basis auto-expires (is_current_flag=false, effective_end_date = change date).
  //   → HR is notified to create a new compensation.basis with the appropriate salary_basis.
  //   Note: Expiry is triggered by the work record lifecycle (contract close → scope change),
  //   not just by scoping fields on this table.
  eligibility_profile_id uuid [null, ref: > eligibility.eligibility_profile.id]  // changed 03Apr2026: FK to centralized eligibility.eligibility_profile
  
  metadata        jsonb
  effective_start date
  effective_end   date [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (code),
    (code, country_code),                        // changed 26Mar2026: country-scoped lookup
    (country_code, legal_entity_id),             // changed 26Mar2026: scope filter
    (config_scope_id),                           // changed 26Mar2026: scope group lookup
    (eligibility_profile_id),                    // changed 03Apr2026: eligibility lookup
    (frequency),
    (effective_start, effective_end)
  }
  
  Note: '''
    changed 03Apr2026: Added eligibility_profile_id (domain=COMPENSATION).
    Consistent with comp_plan, bonus_plan, benefit_plan, pay_element (all use centralized eligibility).
    
    Scoping vs Eligibility — Separation of Concerns:
      country_code / legal_entity_id / config_scope_id → Admin UI filtering ONLY.
        Example: HR filters "show all VN salary bases" using country_code=VN.
      eligibility_profile_id → Business rule: WHO is eligible.
        Example: rule_json {"countries":["VN"],"employee_class":["FULL_TIME"]} → only VN full-time eligible.
    
    Assignment Flow:
      1. Engine evaluates employee against eligibility_profile → populates eligibility_member.
      2. HR opens "Assign Salary" — UI queries eligible salary_bases for this employee.
         Query: JOIN salary_basis sb ON sb.eligibility_profile_id = em.profile_id
                WHERE em.employee_id = :id AND em.end_date IS NULL
      3. HR selects salary_basis + enters amounts → creates compensation.basis.
    
    Auto-expiry: compensation.basis expires when employee loses eligibility due to
    work record lifecycle change (contract close / scope transfer).
    Design doc: compensation-basis-design.md §2 (Scoping vs Eligibility), §6 (Auto-Expiry)
  '''
}


Table comp_core.pay_component_def {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  component_type  varchar(30)         // BASE | ALLOWANCE | BONUS | EQUITY | DEDUCTION | OVERTIME
  frequency       varchar(20)
  taxable         boolean [default:true]
  prorated        boolean [default:true]  // ADDED 21Nov2025: critical for proration logic
  default_currency char(3)
  formula_json    jsonb   [null]          // KEPT 25Nov2025: still used for simple component-specific formulas
  
  // changed 26Mar2026: Multi-country scoping (Option 1 + 2)
  // PHASE 1: country_code filters components per country (e.g., VN-specific allowances vs SG)
  country_code    char(2) [null]                     // changed 26Mar2026: ISO country. NULL = global component
  // PHASE 2: config_scope_id for advanced scope hierarchy
  config_scope_id uuid [ref: > comp_core.config_scope.id, null]  // changed 26Mar2026: Option 2 - scope group
  // Note: legal_entity_id omitted here — components are country-level, LE-specificity via salary_basis
  
  metadata        jsonb   [null]
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  // ADDED 25Nov2025: Enhanced calculation fields for better rule management
  calculation_method    varchar(50) [null]     // FIXED | FORMULA | PERCENTAGE | HOURLY | DAILY
  proration_method      varchar(30) [null]     // CALENDAR_DAYS | WORKING_DAYS | NONE
  tax_treatment         varchar(30) [null]     // FULLY_TAXABLE | TAX_EXEMPT | PARTIALLY_EXEMPT
  tax_exempt_threshold  decimal(18,4) [null]   // For partially exempt (e.g., 730,000 for lunch)
  is_subject_to_si      boolean [default:false] // Subject to social insurance?
  si_calculation_basis  varchar(30) [null]     // FULL_AMOUNT | CAPPED | EXCLUDED
  display_order         int [null]             // Sort order on payslip
  
  Indexes {
    (component_type),
    (is_active) [where: "is_active = true"],
    (code),
    (code, country_code),                        // changed 26Mar2026: country-scoped lookup
    (country_code),                              // changed 26Mar2026: country filter
    (config_scope_id),                           // changed 26Mar2026: scope group lookup
    (effective_start, effective_end),
    (taxable),
    (is_subject_to_si)  // ADDED 25Nov2025
  }
}


Table comp_core.salary_basis_component_map {
  salary_basis_id uuid [ref: > comp_core.salary_basis.id]
  component_id    uuid [ref: > comp_core.pay_component_def.id]
  // changed 23Apr2026: mandatory_flag = true → system auto-creates basis_line when HR sets up compensation.basis
  // with this salary_basis. HR MUST fill amount before status_code → PENDING_APPROVAL / ACTIVE.
  // See: compensation-basis-design.md §8 (Mandatory Component Enforcement)
  mandatory_flag  boolean [default:false]
  default_proration boolean [default:false]  // KEPT 25Nov2025: legacy field
  sort_order      int [default:0]           // ADDED 21Nov2025: display ordering
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  // ADDED 25Nov2025: Enhanced override capabilities
  enable_proration      boolean [null]        // Override component's proration setting
  proration_method      varchar(30) [null]    // Override component's proration method
  calculation_order     int [null]            // Sequence in calculation flow
  display_order         int [null]            // Display order in this basis
  custom_formula_json   jsonb [null]          // Basis-specific formula override

  Indexes { 
    (salary_basis_id, component_id) [unique],
    (component_id),
    (mandatory_flag),
    (calculation_order),  // ADDED 25Nov2025
    (display_order)       // ADDED 25Nov2025
  }
}


/* ----------  Grade & Ladder with SCD-2 ---------- */


Table comp_core.grade_v {               // versioned Grade
  id              uuid [pk]
  grade_code      varchar(20)
  name            varchar(100)
  description     text [null]
  job_level       int [null]              // ADDED 21Nov2025: hierarchy level
  sort_order      int [default:0]         // ADDED 21Nov2025: display ordering
  metadata        jsonb
  effective_start date
  effective_end   date [null]
  version_number  int [default:1]         // ADDED 21Nov2025: SCD-2 version tracking
  previous_version_id uuid [ref: > comp_core.grade_v.id, null]  // ADDED 21Nov2025: version chain
  is_current_version boolean [default:true]  // ADDED 21Nov2025: current version flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail

  Indexes { 
    (grade_code, effective_start),
    (grade_code) [unique, where: "is_current_version = true"],  // ADDED 21Nov2025: unique current version
    (job_level),                                                 // ADDED 21Nov2025: hierarchy queries
    (is_current_version) [where: "is_current_version = true"]   // ADDED 21Nov2025: performance
  }
}


Table comp_core.grade_ladder {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  description     text [null]
  ladder_type     varchar(50) [null]     // ADDED 21Nov2025: MANAGEMENT | TECHNICAL | SPECIALIST
  metadata        jsonb
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (code),
    (is_active) [where: "is_active = true"],
    (ladder_type)
  }
}


Table comp_core.grade_ladder_grade {
  id              uuid [pk]
  ladder_id       uuid [ref: > comp_core.grade_ladder.id]
  grade_v_id      uuid [ref: > comp_core.grade_v.id]
  sort_order      int [default:0]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail

  Indexes { 
    (ladder_id, sort_order),
    (ladder_id, grade_v_id) [unique]  // ADDED 21Nov2025: prevent duplicate mapping
  }
}


Table comp_core.grade_ladder_step {
  id              uuid [pk]
  ladder_id       uuid [ref: > comp_core.grade_ladder.id]
  grade_v_id      uuid [ref: > comp_core.grade_v.id]
  step_number     int
  step_name       varchar(100) [null]
  // REM 21Nov2025: step_amount     decimal(18,2) [null]
  step_amount     decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  currency        char(3) [null]

  // NEW 27Mar2026: AQ-14 Option D — Dual pay scale mode support
  // COEFFICIENT_FORMULA mode: salary = coefficient × VN_LUONG_CO_SO (statutory_rule in PR)
  // TABLE_LOOKUP mode: salary = step_amount (field above)
  // Both modes coexist — PayProfile.grade_step_mode selects which to use
  coefficient     decimal(8,4) [null]                   // NEW 27Mar2026 — hệ số lương (e.g., 2.34, 3.66, 6.20)
  // Ví dụ: Ngạch chuyên viên, Bậc 1 = hệ số 2.34
  //         salary = 2.34 × 2,340,000 VND (lương cơ sở 2025) = 5,475,600 VND
  // Note: coefficient thuộc TR domain (projected/Gross)
  //       VN_LUONG_CO_SO thuộc PR domain (statutory_rule) — TR đọc qua data contract

  // NEW 27Mar2026: AQ-14 — Step Progression Rule (HR-policy, TR domain)
  // Tự động nâng bậc sau N tháng — TR tính projected, không phải PR
  months_to_next_step smallint [null]                   // NEW 27Mar2026 — số tháng tối thiểu ở bậc này trước khi nâng bậc (NULL = không tự động)
  auto_advance    boolean [default: false]              // NEW 27Mar2026 — true = tự động nâng bậc khi đủ months_to_next_step
  // Ví dụ: Bậc 1 (months=36, auto=true) → sau 3 năm tự nâng lên Bậc 2
  // Quy trình: TR scheduled job check → nếu đủ điều kiện → tạo compensation_event STEP_ADVANCEMENT

  effective_start date
  effective_end   date [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail

  Indexes { 
    (ladder_id, step_number),
    (ladder_id, grade_v_id, step_number, effective_start) [unique]
  }

  Note: '''
    CHANGED 27Mar2026: AQ-14 Option D — Dual Pay Scale Mode.
    Supports two modes selected by pay_master.pay_profile.grade_step_mode (PR domain):
      TABLE_LOOKUP: salary = step_amount (set directly by HR)
      COEFFICIENT_FORMULA: salary = coefficient × VN_LUONG_CO_SO (statutory base)
    Cross-ref: pay_master.pay_profile.grade_step_mode (5.Payroll.V4.dbml, line ~475)
               Only applicable when pay_master.pay_profile.pay_method = GRADE_STEP.
    Domain boundary: coefficient + step_amount = TR projected (Gross)
                     VN_LUONG_CO_SO = PR statutory_rule (actual Net calc)
    Step progression: months_to_next_step + auto_advance = TR HR-policy rule
    
    ORPHAN CONSTRAINT (changed 06Apr2026):
    Direct FKs (ladder_id, grade_v_id) are supplementary for query performance.
    Application layer MUST verify: grade_ladder_grade(ladder_id, grade_v_id) record
    exists BEFORE creating a step for the same pair.
    Rule: No grade_ladder_step without a corresponding grade_ladder_grade entry.
  '''
}


/* ----------  Pay Range (multi-scope) ---------- */

Table comp_core.pay_range {
  id              uuid [pk]
  grade_v_id      uuid [ref: > comp_core.grade_v.id]
  scope_type      varchar(20)                     // GLOBAL | LEGAL_ENTITY | BUSINESS_UNIT | POSITION
  scope_uuid      uuid                            // dynamic FK — see scope resolution Note below
  currency        char(3)
  // REM 21Nov2025: min_amount      decimal(18,2)
  // REM 21Nov2025: mid_amount      decimal(18,2)
  // REM 21Nov2025: max_amount      decimal(18,2)
  min_amount      decimal(18,4)  // CHANGED 21Nov2025: increased precision for forex
  mid_amount      decimal(18,4)  // CHANGED 21Nov2025: increased precision for forex
  max_amount      decimal(18,4)  // CHANGED 21Nov2025: increased precision for forex
  range_spread_pct decimal(5,2) [null]  // ADDED 21Nov2025: calculated (max-min)/mid*100
  metadata        jsonb   [null]
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail

  Indexes { 
    (grade_v_id, scope_type, scope_uuid, effective_start),
    (grade_v_id, is_active) [where: "is_active = true"],  // ADDED 21Nov2025: performance
    (scope_type, scope_uuid),                              // ADDED 21Nov2025: scope queries
    (effective_start, effective_end)                       // ADDED 21Nov2025: temporal queries
  }
  
  Note: '''
    changed 06Apr2026: scope_uuid is a dynamic FK — application layer enforces referential integrity.
    Resolution table (scope_type → target):
      GLOBAL       → scope_uuid = NULL (applies to all)
      LEGAL_ENTITY → scope_uuid → org_legal.entity.id
      BUSINESS_UNIT→ scope_uuid → org.business_unit.id
      POSITION     → scope_uuid → org.position.id
    Priority: POSITION(40) > BUSINESS_UNIT(30) > LEGAL_ENTITY(20) > GLOBAL(0)
    Resolution: most specific (highest priority) scope wins for a given employee.
    Compa-ratio = (employee current salary / mid_amount) × 100.
    range_spread_pct = (max_amount - min_amount) / mid_amount × 100 (computed, stored for query).
  '''
}


/* ----------  Compensation Review Cycle ---------- */


Table comp_core.comp_plan {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  description     text [null]           // ADDED 21Nov2025: detailed description
  plan_type       varchar(30)          // MERIT | PROMOTION | MARKET_ADJUSTMENT | NEW_HIRE | EQUITY_CORRECTION | AD_HOC
  eligibility_rule jsonb [null]                 // changed 26Mar2026: G6 - DEPRECATED. Use eligibility_profile_id instead
  eligibility_profile_id uuid [null, ref: > eligibility.eligibility_profile.id]  // changed 26Mar2026: G6+F2 - FK to centralized eligibility.eligibility_profile
  guideline_json  jsonb [null]         // ADDED 21Nov2025: merit matrices, guidelines, approval thresholds
  
  // changed 26Mar2026: Multi-country/LE scoping (Option 1 + 2)
  country_code    char(2) [null]                     // changed 26Mar2026: plan cho country nào. NULL = global
  legal_entity_id uuid [null]                        // changed 26Mar2026: plan cho LE nào. NULL = all LEs
  config_scope_id uuid [ref: > comp_core.config_scope.id, null]  // changed 26Mar2026: Option 2 - scope group
  
  metadata        jsonb [null]
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (code),
    (code, country_code),                        // changed 26Mar2026: country-scoped lookup
    (country_code, legal_entity_id),             // changed 26Mar2026: scope filter
    (config_scope_id),                           // changed 26Mar2026: scope group lookup
    (plan_type),
    (is_active) [where: "is_active = true"]
  }
}


Table comp_core.comp_cycle {
  id              uuid [pk]
  plan_id         uuid [ref: > comp_core.comp_plan.id]
  code            varchar(50) [unique]  // ADDED 21Nov2025: cycle identifier
  name            varchar(200)
  description     text [null]           // ADDED 21Nov2025: cycle description
  period_start    date
  period_end      date
  effective_date  date                  // ADDED 21Nov2025: when adjustments take effect
  // REM 21Nov2025: budget_amount   decimal(18,2) [null]
  budget_amount   decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  budget_currency char(3) [null]        // ADDED 21Nov2025: explicit currency
  // workflow_state  jsonb [null]    // DEPRECATED 27Mar2026 → Temporal workflow engine
  status          varchar(20) [default:'DRAFT']  // DRAFT | OPEN | IN_REVIEW | APPROVED | CLOSED | CANCELLED
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  closed_date     timestamp [null]              // ADDED 21Nov2025: when cycle closed
  closed_by       uuid [null]                   // ADDED 21Nov2025: who closed cycle
  
  Indexes {
    (plan_id),
    (code),
    (status),
    (period_start, period_end),
    (effective_date)
  }
}


Table comp_core.comp_adjustment {
  id              uuid [pk]
  cycle_id        uuid [ref: > comp_core.comp_cycle.id]
  employee_id     uuid [ref: > employment.employee.id]
  assignment_id   uuid [ref: > employment.assignment.id]  // ADDED 21Nov2025: link to assignment for grade context
  component_id    uuid [ref: > comp_core.pay_component_def.id]
  // REM 21Nov2025: current_amount  decimal(18,2) [null]
  // REM 21Nov2025: proposed_amount decimal(18,2)
  current_amount  decimal(18,4)  // CHANGED 21Nov2025: increased precision
  proposed_amount decimal(18,4)  // CHANGED 21Nov2025: increased precision
  increase_amount decimal(18,4) [null]  // ADDED 21Nov2025: computed/stored field
  increase_pct    decimal(7,4) [null]   // ADDED 21Nov2025: computed/stored field
  currency        char(3)
  rationale_code  varchar(50) [null]    // ADDED 21Nov2025: standardized reason codes
  // REM 21Nov2025: note            text [null]
  rationale_text  text [null]           // CHANGED 21Nov2025: renamed from note for clarity
  // changed 06Apr2026: default changed from PENDING → DRAFT. Added SUBMITTED state.
  // Workflow detail (chain, level, SLA) → Temporal Workflow Engine — NOT stored here.
  // DB stores final outcome only: approval_status + decision_note + decision_date.
  approval_status varchar(20) [default:'DRAFT']  // DRAFT | SUBMITTED | PENDING | APPROVED | REJECTED | WITHDRAWN
  // workflow_state  jsonb [null]    // DEPRECATED 27Mar2026 → Temporal workflow engine
  submitted_date  timestamp [null]      // ADDED 21Nov2025: when submitted for approval
  submitted_by    uuid [null]           // ADDED 21Nov2025: who submitted
  approver_emp_id uuid [ref: > employment.employee.id, null]
  // REM 21Nov2025: decision_date   date [null]
  decision_date   timestamp [null]      // CHANGED 21Nov2025: timestamp for precise tracking
  decision_note   text [null]           // ADDED 21Nov2025: approver's decision notes
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail

  Indexes { 
    (cycle_id, employee_id),
    (cycle_id, approval_status),
    (employee_id),                       // ADDED 21Nov2025: employee history queries
    (approver_emp_id),                   // ADDED 21Nov2025: approver workload queries
    (assignment_id)                      // ADDED 21Nov2025: assignment-based queries
  }
}


Table comp_core.employee_comp_snapshot {
  id              uuid [pk]
  employee_id     uuid [ref: > employment.employee.id]
  assignment_id   uuid [ref: > employment.assignment.id]
  component_id    uuid [ref: > comp_core.pay_component_def.id]
  // REM 21Nov2025: amount          decimal(18,2)
  amount          decimal(18,4)         // CHANGED 21Nov2025: increased precision
  currency        char(3)
  frequency       varchar(20)
  status          varchar(20)          // PLANNED | ACTIVE | EXPIRED
  source_type     varchar(30) [null]   // ADDED 21Nov2025: COMP_ADJUSTMENT | OFFER_PACKAGE | MASS_UPLOAD | MANUAL
  source_ref      varchar(100) [null]  // CHANGED 21Nov2025: increased length from 50 to 100
  effective_start date
  effective_end   date [null]
  metadata        jsonb [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail

  Indexes { 
    (employee_id, component_id, effective_start),
    (employee_id, status, effective_start) [where: "status = 'ACTIVE'"],
    (component_id, status),
    (effective_start, effective_end),              // ADDED 21Nov2025: temporal queries
    (assignment_id),                                // ADDED 21Nov2025: assignment queries
    (source_type, source_ref)                      // ADDED 21Nov2025: source tracking
  }
}


/* ----------  Budget Management ---------- */
// NEW TABLE 21Nov2025: Budget allocation and tracking by organizational scope
Table comp_core.budget_allocation {
  id              uuid [pk]
  cycle_id        uuid [ref: > comp_core.comp_cycle.id]
  scope_type      varchar(30)  // GLOBAL | LEGAL_ENTITY | BUSINESS_UNIT | DEPARTMENT | TEAM
  scope_uuid      uuid [null]
  allocated_amount decimal(18,4)
  utilized_amount decimal(18,4) [default:0]
  utilization_pct decimal(5,2) [null]  // computed: (utilized/allocated)*100
  currency        char(3)
  created_date    timestamp [default:`now()`]
  created_by      uuid
  updated_date    timestamp [null]

  Indexes {
    (cycle_id, scope_type, scope_uuid) [unique],
    (cycle_id),
    (scope_type, scope_uuid)
  }
  
  Note: '''
    changed 06Apr2026: scope_uuid is a dynamic FK — application layer enforces referential integrity.
    Resolution table (scope_type → target):
      GLOBAL       → scope_uuid = NULL
      LEGAL_ENTITY → scope_uuid → org_legal.entity.id
      BUSINESS_UNIT→ scope_uuid → org.business_unit.id
      DEPARTMENT   → scope_uuid → org.department.id
      TEAM         → scope_uuid → org.team.id
    utilization_pct = (utilized_amount / allocated_amount) × 100 (computed, stored for reporting).
  '''
}


//***************************************************
// * 2.  Variable Pay – Bonus / Equity / Commission
// ***************************************************/


Table comp_incentive.bonus_plan {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  description     text [null]           // ADDED 21Nov2025: plan description
  bonus_type      varchar(30)          // STI | LTI | COMMISSION
  equity_flag     boolean [default:false]
  formula_json    jsonb [null]
  eligibility_rule jsonb [null]                 // changed 26Mar2026: G6 - DEPRECATED. Use eligibility_profile_id instead
  eligibility_profile_id uuid [null, ref: > eligibility.eligibility_profile.id]  // changed 26Mar2026: G6+F2 - FK to centralized eligibility.eligibility_profile
  
  // changed 26Mar2026: Multi-country/LE scoping (Option 1 + 2)
  country_code    char(2) [null]                     // changed 26Mar2026: bonus plan cho country nào. NULL = global
  legal_entity_id uuid [null]                        // changed 26Mar2026: bonus plan cho LE nào. NULL = all LEs
  config_scope_id uuid [ref: > comp_core.config_scope.id, null]  // changed 26Mar2026: Option 2 - scope group
  
  metadata        jsonb [null]
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (code),
    (code, country_code),                        // changed 26Mar2026: country-scoped lookup
    (country_code, legal_entity_id),             // changed 26Mar2026: scope filter
    (config_scope_id),                           // changed 26Mar2026: scope group lookup
    (bonus_type),
    (is_active) [where: "is_active = true"]
  }
}


Table comp_incentive.bonus_cycle {
  id              uuid [pk]
  plan_id         uuid [ref: > comp_incentive.bonus_plan.id]
  code            varchar(50) [unique]  // ADDED 21Nov2025: cycle identifier
  name            varchar(200)
  description     text [null]           // ADDED 21Nov2025: cycle description
  period_start    date
  period_end      date
  // REM 21Nov2025: budget_amount   decimal(18,2)
  budget_amount   decimal(18,4)         // CHANGED 21Nov2025: increased precision
  currency        char(3)
  // workflow_state  jsonb [null]    // DEPRECATED 27Mar2026 → Temporal workflow engine
  status          varchar(20)
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (plan_id),
    (code),
    (status),
    (period_start, period_end)
  }
}


Table comp_incentive.bonus_pool {
  id              uuid [pk]
  cycle_id        uuid [ref: > comp_incentive.bonus_cycle.id]
  legal_entity_id uuid [ref: > org_legal.entity.id]
  name            varchar(200)
  // REM 21Nov2025: budget_amount   decimal(18,2)
  budget_amount   decimal(18,4)         // CHANGED 21Nov2025: increased precision
  utilized_amount decimal(18,4) [default:0]  // ADDED 21Nov2025: track utilization
  currency        char(3)
  metadata        jsonb [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  Indexes {
    (cycle_id),
    (legal_entity_id)
  }
}


Table comp_incentive.bonus_allocation {
  id              uuid [pk]
  pool_id         uuid [ref: > comp_incentive.bonus_pool.id]
  employee_id     uuid [ref: > employment.employee.id]
  // REM 21Nov2025: proposed_amount decimal(18,2)
  // REM 21Nov2025: approved_amount decimal(18,2) [null]
  proposed_amount decimal(18,4)         // CHANGED 21Nov2025: increased precision
  approved_amount decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  currency        char(3)
  status          varchar(20)    // DRAFT | PENDING | APPROVED | REJECTED
  approver_emp_id uuid [ref: > employment.employee.id, null]
  // REM 21Nov2025: decision_date   date [null]
  decision_date   timestamp [null]      // CHANGED 21Nov2025: timestamp for precision
  decision_note   text [null]           // ADDED 21Nov2025: approver notes

  // changed 23Apr2026: Link to performance review for performance-based bonus
  // null     = bonus không dựa vào performance (retention, spot, project bonus)
  // not null = performance-based bonus; amount chịu ảnh hưởng của employee_review.performance_tier
  performance_review_id uuid [null, ref: > performance.employee_review.id]

  metadata        jsonb [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  Indexes {
    (pool_id),
    (employee_id),
    (status),
    (approver_emp_id),
    (performance_review_id)  // changed 23Apr2026: performance-based bonus lookup
  }
}



/* ---- Equity Grant life-cycle ---- */
Table comp_incentive.equity_grant {
  id              uuid [pk]
  employee_id     uuid [ref: > employment.employee.id]
  plan_id         uuid [ref: > comp_incentive.bonus_plan.id]
  grant_number    varchar(50) [unique]  // ADDED 21Nov2025: unique grant identifier
  grant_date      date
  unit_type       varchar(20)           // RSU | OPTION | SAR
  total_units     int
  vested_units    int [default:0]       // ADDED 21Nov2025: track vested units
  exercised_units int [default:0]       // ADDED 21Nov2025: track exercised units
  forfeited_units int [default:0]       // ADDED 21Nov2025: track forfeited units
  // REM 21Nov2025: strike_price    decimal(18,4) [null]
  strike_price    decimal(18,6) [null]  // CHANGED 21Nov2025: increased precision for stock price
  fair_market_value decimal(18,6) [null]  // ADDED 21Nov2025: FMV at grant date
  expiry_date     date [null]
  vesting_sched_json jsonb
  status          varchar(20)           // ACTIVE | FULLY_VESTED | FORFEITED | EXPIRED | EXERCISED
  metadata        jsonb [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (employee_id),
    (grant_number),
    (grant_date),
    (status)
  }
}


Table comp_incentive.equity_vesting_event {
  id              uuid [pk]
  grant_id        uuid [ref: > comp_incentive.equity_grant.id]
  vest_date       date
  vested_units    int
  event_type      varchar(20)          // SCHEDULED | ACCELERATED | FORFEIT
  payroll_batch_id uuid [null]
  metadata        jsonb [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  Indexes {
    (grant_id),
    (vest_date),
    (event_type)
  }
}


Table comp_incentive.equity_txn {
  id              uuid [pk]
  grant_id        uuid [ref: > comp_incentive.equity_grant.id]
  txn_date        date
  txn_type        varchar(20)          // EXERCISE | CANCEL | FORFEIT | VEST
  units           int
  // REM 21Nov2025: price_per_unit  decimal(18,4) [null]
  // REM 21Nov2025: cash_value      decimal(18,2) [null]
  price_per_unit  decimal(18,6) [null]  // CHANGED 21Nov2025: increased precision for stock price
  cash_value      decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  payroll_batch_id uuid [null]
  metadata        jsonb [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  Indexes {
    (grant_id),
    (txn_date),
    (txn_type)
  }
}


//***************************************************
// * 3.  Benefits, Reimbursement & Healthcare
// ***************************************************/

// REM 21Nov2025: Removed duplicate benefit.benefit_program table
// Use benefit.benefit_plan instead for consistency

Table benefit.benefit_plan {
  id              uuid        [pk]
  code            varchar(50) [unique]
  name            varchar(255)
  description     text [null]           // ADDED 21Nov2025: plan description
  plan_category   varchar(50)           // CHANGED 21Nov2025: renamed from plan_category_code for clarity
                                        // MEDICAL | DENTAL | VISION | LIFE | DISABILITY | RETIREMENT | PERK | WELLNESS
  provider_name   varchar(255) [null]
  sponsor_legal_entity_id uuid [ref: > org_legal.legal_entity.id, null]
  eligibility_rule_json jsonb [null]            // changed 26Mar2026: G5 - DEPRECATED. Use eligibility_profile_id instead
  eligibility_profile_id uuid [null, ref: > eligibility.eligibility_profile.id]  // changed 26Mar2026: G5+F2 - FK to centralized eligibility.eligibility_profile
  coverage_options_json jsonb [null]
  // REM 21Nov2025: currency_id     uuid [ref: > common.currency.id, null]
  currency        char(3) [null]        // CHANGED 21Nov2025: standardized to char(3) like other tables
  premium_type    varchar(50) [null]    // CHANGED 21Nov2025: renamed from premium_type_code
                                        // EMPLOYEE | EMPLOYER | SHARED
  metadata        jsonb [null]
  effective_start date                  // CHANGED 21Nov2025: renamed from effective_start_date
  effective_end   date [null]           // CHANGED 21Nov2025: renamed from effective_end_date
  is_active       boolean [default:true]  // CHANGED 21Nov2025: renamed from is_current_flag
  created_date    timestamp [default:`now()`]  // CHANGED 21Nov2025: renamed from created_at
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]              // CHANGED 21Nov2025: renamed from updated_at
  updated_by      uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (code),
    (plan_category),
    (is_active) [where: "is_active = true"]
  }
}


Table benefit.benefit_option {
  id              uuid [pk]
  plan_id         uuid [ref: > benefit.benefit_plan.id]
  code            varchar(50) [unique]
  name            varchar(200)
  coverage_tier   varchar(30)          // EMPLOYEE_ONLY | EMPLOYEE_SPOUSE | EMPLOYEE_FAMILY
  // REM 21Nov2025: cost_employee   decimal(18,2) [null]
  // REM 21Nov2025: cost_employer   decimal(18,2) [null]
  cost_employee   decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  cost_employer   decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  currency        char(3)
  formula_json    jsonb [null]
  metadata        jsonb [null]
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  Indexes {
    (plan_id),
    (code),
    (is_active) [where: "is_active = true"]
  }
}


// changed 26Mar2026: G5 - DEPRECATED. Migrate to centralized eligibility.eligibility_profile (domain='BENEFITS')
// Keep for backward compatibility during migration. New implementations should use centralized eligibility.
// changed 26Mar2026: F3 - Migration timeline: Remove in v6.0 (target Q3 2026). Drop benefit.eligibility_profile + benefit.plan_eligibility after full migration.
Table benefit.eligibility_profile {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  rule_json       jsonb
  metadata        jsonb [null]
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  Indexes {
    (code),
    (is_active) [where: "is_active = true"]
  }
}


// changed 26Mar2026: G5 - DEPRECATED. Use benefit_plan.eligibility_profile_id → centralized eligibility instead
// changed 26Mar2026: F3 - Migration timeline: Remove in v6.0 (target Q3 2026)
Table benefit.plan_eligibility {
  plan_id         uuid [ref: > benefit.benefit_plan.id]
  eligibility_id  uuid [ref: > benefit.eligibility_profile.id]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail

  Indexes { (plan_id, eligibility_id) [unique] }
}


Table benefit.enrollment {
  id                uuid [pk]
  employee_id       uuid [ref: > employment.employee.id]
  option_id         uuid [ref: > benefit.benefit_option.id]
  coverage_start    date
  coverage_end      date [null]
  status            varchar(20)        // ACTIVE | WAIVED | TERMINATED | PENDING
  // REM 21Nov2025: premium_employee  decimal(18,2) [null]
  // REM 21Nov2025: premium_employer  decimal(18,2) [null]
  premium_employee  decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  premium_employer  decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  currency          char(3)
  metadata          jsonb [null]
  created_date      timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by        uuid                          // ADDED 21Nov2025: audit trail
  updated_date      timestamp [null]              // ADDED 21Nov2025: audit trail
  updated_by        uuid [null]                   // ADDED 21Nov2025: audit trail
  
  Indexes {
    (employee_id),
    (option_id),
    (status),
    (coverage_start, coverage_end)
  }
}


Table benefit.reimbursement_request {
  id              uuid [pk]
  employee_id     uuid [ref: > employment.employee.id]
  option_id       uuid [ref: > benefit.benefit_option.id]
  request_type    varchar(30)          // EXPENSE | MEDICAL | WELLNESS | EDUCATION
  request_date    date
  status          varchar(20)          // DRAFT | SUBMITTED | APPROVED | REJECTED | PAID
  // REM 21Nov2025: total_amount    decimal(18,2) [null]
  // REM 21Nov2025: approved_amount decimal(18,2) [null]
  total_amount    decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  approved_amount decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  currency        char(3)
  approver_id     uuid [ref: > employment.employee.id, null]  // ADDED 21Nov2025: who approved
  decision_date   timestamp [null]      // ADDED 21Nov2025: when decision made
  decision_note   text [null]           // ADDED 21Nov2025: approver notes
  metadata        jsonb [null]
  created_at      timestamp [default:`now()`]
  created_by      uuid                  // ADDED 21Nov2025: audit trail
  updated_date    timestamp [null]      // ADDED 21Nov2025: audit trail
  updated_by      uuid [null]           // ADDED 21Nov2025: audit trail
  
  Indexes {
    (employee_id),
    (option_id),
    (status),
    (request_date),
    (approver_id)
  }
}


Table benefit.reimbursement_line {
  id              uuid [pk]
  request_id      uuid [ref: > benefit.reimbursement_request.id]
  line_number     int
  description     varchar(255)
  // REM 21Nov2025: amount          decimal(18,2)
  amount          decimal(18,4)         // CHANGED 21Nov2025: increased precision
  currency        char(3)
  metadata        jsonb [null]

  Indexes { (request_id, line_number) [unique] }
}


Table benefit.healthcare_claim_header {
  id              uuid [pk]
  employee_id     uuid [ref: > employment.employee.id]
  insurer_claim_id varchar(50) [null]
  service_date    date
  claim_status    varchar(20)          // SUBMITTED | IN_REVIEW | APPROVED | REJECTED | PAID
  // REM 21Nov2025: amount          decimal(18,2)
  amount          decimal(18,4)         // CHANGED 21Nov2025: increased precision
  currency        char(3)
  metadata        jsonb [null]
  created_at      timestamp [default:`now()`]
  created_by      uuid                  // ADDED 21Nov2025: audit trail
  
  Indexes {
    (employee_id),
    (claim_status),
    (service_date)
  }
}


Table benefit.healthcare_claim_line {
  id              uuid [pk]
  claim_header_id uuid [ref: > benefit.healthcare_claim_header.id]
  procedure_code  varchar(50)
  description     text [null]
  // REM 21Nov2025: charge_amount   decimal(18,2)
  // REM 21Nov2025: allowed_amount  decimal(18,2) [null]
  charge_amount   decimal(18,4)         // CHANGED 21Nov2025: increased precision
  allowed_amount  decimal(18,4) [null]  // CHANGED 21Nov2025: increased precision
  currency        char(3)
  metadata        jsonb [null]
  
  Indexes {
    (claim_header_id),
    (procedure_code)
  }
}


//***************************************************
// * 4.  Recognition & Perks
// ***************************************************/


Table recognition.recognition_event_type {
  code            varchar(50) [pk]
  name            varchar(100)
  description     text [null]
  metadata        jsonb [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
}


Table recognition.perk_category {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(100)
  description     text [null]
  is_active       boolean [default:true]
  
  Indexes {
    (code),
    (is_active) [where: "is_active = true"]
  }
}


Table recognition.perk_catalog {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  category_id     uuid [ref: > recognition.perk_category.id]
  points_cost     int
  inventory       int [null]
  redeem_limit_per_employee int [null]
  status          varchar(20) [default:'ACTIVE']
  metadata        jsonb [null]
  effective_start date
  effective_end   date [null]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: audit trail
  created_by      uuid                          // ADDED 21Nov2025: audit trail
  
  Indexes {
    (code),
    (category_id),
    (status),
    (effective_start, effective_end)
  }
}


Table recognition.point_account {
  employee_id     uuid [pk, ref: > employment.employee.id]
  balance         int [default:0]
  lifetime_earned int [default:0]       // ADDED 21Nov2025: total earned all time
  lifetime_spent  int [default:0]       // ADDED 21Nov2025: total spent all time
  last_updated    timestamp [default:`now()`]
  created_date    timestamp [default:`now()`]  // ADDED 21Nov2025: when account created
}


Table recognition.recognition_event {
  id              uuid [pk]
  employee_from_id uuid [ref: > employment.employee.id]
  employee_to_id  uuid [ref: > employment.employee.id]
  event_type_code varchar(50) [ref: > recognition.recognition_event_type.code]
  points_awarded  int
  reason          varchar(30) [null]    // ADDED 21Nov2025: PERFORMANCE | TEAMWORK | INNOVATION | VALUES
  // REM 21Nov2025: status          varchar(20) [default:'APPROVED']
  status          varchar(20) [default:'PENDING']  // CHANGED 21Nov2025: should default to PENDING not APPROVED
  approver_id     uuid [ref: > employment.employee.id, null]
  decision_date   timestamp [null]
  message         text [null]
  created_at      timestamp [default:`now()`]
  metadata        jsonb [null]
  
  Indexes {
    (employee_from_id),
    (employee_to_id),
    (event_type_code),
    (status),
    (created_at)
  }
}


Table recognition.reward_point_txn {
  id              uuid [pk]
  employee_id     uuid [ref: > employment.employee.id]
  points_delta    int                   // positive for earn, negative for spend
  balance_after   int
  txn_type        varchar(30)           // ADDED 21Nov2025: EARNED | SPENT | ADJUSTED | EXPIRED
  reference       varchar(50) [null]
  txn_date        timestamp [default:`now()`]
  metadata        jsonb [null]
  
  Indexes {
    (employee_id, txn_date),
    (txn_type)
  }
}


Table recognition.perk_redeem {
  id              uuid [pk]
  employee_id     uuid [ref: > employment.employee.id]
  perk_id         uuid [ref: > recognition.perk_catalog.id]
  points_spent    int
  status          varchar(20) [default:'REQUESTED']  // REQUESTED | APPROVED | REJECTED | FULFILLED
  request_date    timestamp [default:`now()`]
  fulfillment_date timestamp [null]
  fulfilled_by    uuid [ref: > employment.employee.id, null]  // ADDED 21Nov2025: who fulfilled
  metadata        jsonb [null]
  
  Indexes {
    (employee_id),
    (perk_id),
    (status),
    (request_date)
  }
}


/***************************************************
 * 5.  Total-Reward Offer  (Retention / New hire)
 ***************************************************/


Table tr_offer.offer_template {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  description     text [null]           // ADDED 21Nov2025: template description
  version_no      int [default:1]
  components_json jsonb
  metadata        jsonb [null]
  created_by      uuid [ref: > employment.employee.id]
  created_at      timestamp [default:`now()`]
  effective_start date
  effective_end   date [null]
  is_active       boolean [default:true]  // ADDED 21Nov2025: status flag
  
  Indexes {
    (code, version_no) [unique],
    (is_active) [where: "is_active = true"]
  }
}


Table tr_offer.offer_template_event {
  id              uuid [pk]
  template_id     uuid [ref: > tr_offer.offer_template.id]
  event_type      varchar(50)              // CREATED | UPDATED | ACTIVATED | DEACTIVATED
  event_time      timestamp [default:`now()`]
  event_by        uuid [ref: > employment.employee.id, null]  // ADDED 21Nov2025: who triggered event
  metadata        jsonb [null]
  
  Indexes {
    (template_id, event_time),
    (event_type)
  }
}


Table tr_offer.offer_package {
  id              uuid [pk]
  template_id     uuid [ref: > tr_offer.offer_template.id]
  worker_id       uuid [ref: > person.worker.id]
  employee_id     uuid [ref: > employment.employee.id, null]  // ADDED 21Nov2025: if existing employee
  offer_type      varchar(30) [null]    // ADDED 21Nov2025: NEW_HIRE | PROMOTION | RETENTION | COUNTER_OFFER
  currency        char(3)
  // REM 21Nov2025: total_cash      decimal(18,2)
  // REM 21Nov2025: total_value     decimal(18,2)
  total_fixed_cash decimal(18,4) [null]  // ADDED 21Nov2025: fixed comp only
  total_variable  decimal(18,4) [null]   // ADDED 21Nov2025: variable comp
  total_benefits  decimal(18,4) [null]   // ADDED 21Nov2025: benefits value
  total_cash      decimal(18,4)          // CHANGED 21Nov2025: precision + sum of fixed+variable
  total_value     decimal(18,4)          // CHANGED 21Nov2025: precision + everything
  cost_json       jsonb
  status          varchar(20) [default:'DRAFT']  // DRAFT | PENDING | APPROVED | SENT | VIEWED | ACCEPTED | REJECTED | EXPIRED
  approved_by     uuid [ref: > employment.employee.id, null]
  approved_at     timestamp [null]
  sent_date       date [null]           // ADDED 21Nov2025: when sent to candidate
  expires_at      date [null]
  metadata        jsonb [null]
  created_at      timestamp [default:`now()`]
  created_by      uuid                  // ADDED 21Nov2025: who created offer
  updated_at      timestamp [null]
  updated_by      uuid [null]           // ADDED 21Nov2025: who last updated
  
  Indexes {
    (worker_id),
    (employee_id),
    (status),
    (offer_type)
  }
}


Table tr_offer.offer_event {
  id              uuid [pk]
  package_id      uuid [ref: > tr_offer.offer_package.id]
  event_type      varchar(50)              // SENT | VIEWED | REMINDER | ACCEPTED | REJECTED | EXPIRED | WITHDRAWN
  event_time      timestamp [default:`now()`]
  event_by        uuid [null]           // ADDED 21Nov2025: who/what triggered event
  metadata        jsonb [null]
  
  Indexes {
    (package_id, event_time),
    (event_type)
  }
}


Table tr_offer.offer_acceptance {
  id              uuid [pk]
  package_id      uuid [ref: > tr_offer.offer_package.id]
  accepted        boolean
  accepted_at     timestamp [null]
  rejected_at     timestamp [null]      // ADDED 21Nov2025: rejection timestamp
  rejection_reason text [null]          // ADDED 21Nov2025: why rejected
  signed_doc_url  varchar(255) [null]
  metadata        jsonb [null]
}


//***************************************************
// * 6.  Taxable Benefit Bridge
// ***************************************************/


Table tr_taxable.taxable_item {
  id              uuid [pk]
  source_module   varchar(30)          // BENEFIT | EQUITY | PERK | RECOGNITION
  source_table    varchar(50)
  source_id       uuid
  employee_id     uuid [ref: > employment.employee.id]
  benefit_type    varchar(50)              // GIFT_CARD | CAR_ALLOWANCE | EQUITY_VEST | etc
  // REM 21Nov2025: taxable_amount  decimal(18,2)
  taxable_amount  decimal(18,4)         // CHANGED 21Nov2025: increased precision
  currency        char(3)
  tax_year        smallint
  payroll_batch_id uuid [null]
  processed_flag  boolean [default:false]
  processed_at    timestamp [null]
  metadata        jsonb [null]
  created_at      timestamp [default:`now()`]
  
  Indexes {
    (employee_id, tax_year),
    (source_module, source_table, source_id),
    (processed_flag) [where: "processed_flag = false"],
    (payroll_batch_id)
  }
}


//***************************************************
// * 7.  Total-Reward Statement & Analytics
// ***************************************************/


Table tr_statement.statement_config {
  id              uuid [pk]
  code            varchar(50) [unique]
  name            varchar(200)
  description     text [null]           // ADDED 21Nov2025: config description
  version_no      int [default:1]
  layout_json     jsonb
  schedule_json   jsonb [null]
  metadata        jsonb [null]
  is_active       boolean [default:true]
  created_by      uuid [ref: > employment.employee.id, null]
  created_at      timestamp [default:`now()`]
  updated_at      timestamp [null]
  updated_by      uuid [null]           // ADDED 21Nov2025: who last updated

  Indexes { 
    (code, version_no) [unique],
    (is_active) [where: "is_active = true"]
  }
}


Table tr_statement.statement_section {
  code            varchar(50) [pk]
  name            varchar(100)
  sort_order      int [default:0]
  metadata        jsonb [null]
  is_active       boolean [default:true]
}


Table tr_statement.statement_job {
  id              uuid [pk]
  config_id       uuid [ref: > tr_statement.statement_config.id]
  period_start    date
  period_end      date
  status          varchar(20)              // PENDING | RUNNING | COMPLETED | FAILED
  started_at      timestamp [null]
  completed_at    timestamp [null]
  file_url        varchar(255) [null]
  error_message   text [null]           // ADDED 21Nov2025: error details if failed
  metadata        jsonb [null]
  created_by      uuid [ref: > employment.employee.id, null]
  created_at      timestamp [default:`now()`]
  updated_at      timestamp [null]

  Indexes { 
    (config_id, period_start, period_end) [unique],
    (status),
    (created_at)
  }
}


Table tr_statement.statement_line {
  id              uuid [pk]
  job_id          uuid [ref: > tr_statement.statement_job.id]
  employee_id     uuid [ref: > employment.employee.id]
  section_code    varchar(50) [ref: > tr_statement.statement_section.code, null]
  statement_json  jsonb
  metadata        jsonb [null]

  Indexes { 
    (job_id, employee_id),
    (employee_id),
    (section_code)
  }
}


//***************************************************
// * 8.  Audit & Compliance
// ***************************************************/

// NEW TABLE 21Nov2025: Comprehensive audit trail for all Total Rewards modules
Table tr_audit.audit_log {
  id              uuid [pk]
  event_type      varchar(50)          // COMP_CHANGED | BONUS_APPROVED | EQUITY_VESTED | etc
  entity_type     varchar(50)          // TABLE name
  entity_id       uuid                 // Record ID
  action          varchar(20)          // CREATE | UPDATE | DELETE | APPROVE | REJECT | VIEW
  user_id         uuid                 // Who performed action
  user_role       varchar(50) [null]
  ip_address      inet [null]
  user_agent      text [null]
  request_id      uuid [null]
  old_values      jsonb [null]         // Previous state
  new_values      jsonb [null]         // New state
  change_summary  text [null]          // Human-readable change description
  reason          text [null]          // Why change was made
  timestamp       timestamp [default:`now()`]
  
  Indexes {
    (entity_type, entity_id),
    (user_id, timestamp),
    (timestamp),
    (event_type),
    (action)
  }
}

// Consider partitioning audit_log by month for performance:
// CREATE TABLE tr_audit.audit_log_2025_11 PARTITION OF tr_audit.audit_log
//   FOR VALUES FROM ('2025-11-01') TO ('2025-12-01');


//***************************************************
// * 9. CALCULATION RULES & FORMULAS (NEW MODULE)
//      ADDED 25Nov2025: Global calculation rules
//      changed 27Mar2026: ADR Option D – Domain Boundary
//      TR only owns HR-policy rules (up to Gross).
//      Statutory rules (TAX, SI, OT) → PR domain (pay_master.statutory_rule)
//      Xem CHANGELOG [27Mar2026-b] để biết chi tiết.
// ***************************************************/

// Layer 3: Global Calculation Rules
Table comp_core.calculation_rule_def {
  id              uuid [pk]
  code            varchar(50) [unique, not null]
  name            varchar(200) [not null]
  // changed 27Mar2026: ADR Option D — restrict to HR-policy categories only
  // Statutory categories (TAX, SOCIAL_INSURANCE, OVERTIME) → PR domain: pay_master.statutory_rule
  // V3: TAX | SOCIAL_INSURANCE | PRORATION | OVERTIME | ROUNDING | FOREX | ANNUALIZATION
  // V4: PRORATION | ROUNDING | FOREX | ANNUALIZATION | COMPENSATION_POLICY
  rule_category   varchar(30) [not null]   // PRORATION | ROUNDING | FOREX | ANNUALIZATION | COMPENSATION_POLICY
  rule_type       varchar(30) [not null]   // FORMULA | LOOKUP_TABLE | CONDITIONAL | RATE_TABLE | PROGRESSIVE
  
  country_code    char(2) [null]           // ISO country code: VN, SG, US, etc. NULL = global
  jurisdiction    varchar(50) [null]       // State/Province/City if applicable
  
  formula_json    jsonb [not null]         // Actual calculation logic/data
  
  description     text [null]
  legal_reference text [null]              // Legal citation (e.g., "Article 107, Labor Code 2019")
  
  effective_start date [not null]
  effective_end   date [null]              // NULL = still effective
  
  version_number  int [default:1]          // For version tracking
  previous_version_id uuid [ref: > comp_core.calculation_rule_def.id, null]
  is_current_version boolean [default:true]
  
  metadata        jsonb [null]
  
  created_date    timestamp [default:`now()`]
  created_by      uuid [not null]
  updated_date    timestamp [null]
  updated_by      uuid [null]
  
  Indexes {
    (code),
    (rule_category),
    (rule_type),
    (country_code),
    (code, effective_start),
    (code, is_current_version) [unique, where: "is_current_version = true"],
    (is_current_version) [where: "is_current_version = true"],
    (rule_category, country_code),
    (effective_start, effective_end)
  }
  
  Note: '''
  25Nov2025: Global calculation rules table
  changed 27Mar2026: ADR Option D – Domain Boundary Enforcement
  - TR chỉ sở hữu HR-policy rules (tính đến Gross):
    PRORATION, ROUNDING, FOREX, ANNUALIZATION, COMPENSATION_POLICY
  - Statutory rules (TAX, SI, OT) đã chuyển sang PR domain:
    → pay_master.statutory_rule (Payroll module)
  - Versioned with SCD-2 approach (previous_version_id)
  - Country-specific via country_code
  - formula_json contains the actual calculation logic
  Examples (TR scope only):
    - VN_PRORATION_2025: Proration rules for mid-month changes
    - ANNUALIZATION_MONTHLY: Convert monthly → annual for comp planning
    - FOREX_DAILY: Currency conversion for multi-currency comp
  Migrated to PR (no longer created here):
    - VN_PIT_2025 → pay_master.statutory_rule (PR)
    - VN_SI_2025 → pay_master.statutory_rule (PR)
    - VN_OT_MULT_2019 → pay_master.statutory_rule (PR)
    - SG_CPF_2025 → pay_master.statutory_rule (PR)
  '''
}


// Bridge table: Link components to specific calculation rules
Table comp_core.component_calculation_rule {
  id              uuid [pk]
  component_id    uuid [ref: > comp_core.pay_component_def.id, not null]
  rule_id         uuid [ref: > comp_core.calculation_rule_def.id, not null]
  
  // changed 27Mar2026: ADR Option D — restrict to HR-policy scopes
  // V3: COMPONENT_CALC | TAX | PRORATION | VALIDATION | SI_CALCULATION
  // V4: COMPONENT_CALC | PRORATION | VALIDATION | ANNUALIZATION
  // TAX, SI_CALCULATION → PR domain (pay_engine handles these)
  rule_scope      varchar(30) [not null]   // COMPONENT_CALC | PRORATION | VALIDATION | ANNUALIZATION
  execution_order int [default:0]          // When multiple rules apply to same component
  
  override_params jsonb [null]             // Component-specific parameter overrides
  
  effective_start date [not null]
  effective_end   date [null]
  
  created_date    timestamp [default:`now()`]
  created_by      uuid [not null]
  updated_date    timestamp [null]
  updated_by      uuid [null]
  
  Indexes {
    (component_id, rule_id, effective_start) [unique],
    (component_id, rule_scope),
    (rule_id),
    (component_id, rule_scope, execution_order),
    (effective_start, effective_end)
  }
  
  Note: '''
  25Nov2025: Links pay components to calculation rules
  changed 27Mar2026: ADR Option D — scopes restricted to HR-policy only
  - Allows component-specific rule application (proration, annualization, validation)
  - execution_order determines calculation sequence
  - override_params can customize rule behavior per component
  - TAX, SI_CALCULATION scopes → PR engine (pay_engine.calculation_step)
  Example: LUONG_CO_BAN component → VN_PRORATION_2025 rule
  '''
}


// Bridge table: Link salary basis to calculation rules
Table comp_core.basis_calculation_rule {
  id              uuid [pk]
  salary_basis_id uuid [ref: > comp_core.salary_basis.id, not null]
  rule_id         uuid [ref: > comp_core.calculation_rule_def.id, not null]
  
  // changed 27Mar2026: ADR Option D — restrict to HR-policy scopes
  // V3: PRORATION | TAX | ROUNDING | ANNUALIZATION | SI_CALCULATION | GROSS_TO_NET
  // V4: PRORATION | ROUNDING | ANNUALIZATION
  // TAX, SI_CALCULATION, GROSS_TO_NET → PR domain (pay_engine handles Gross→Net)
  rule_scope      varchar(30) [not null]   // PRORATION | ROUNDING | ANNUALIZATION
  execution_order int [default:0]          // Calculation sequence (e.g., 1=proration, 2=rounding, 3=annualization)
  
  override_params jsonb [null]             // Basis-specific parameter overrides
  
  effective_start date [not null]
  effective_end   date [null]
  
  created_date    timestamp [default:`now()`]
  created_by      uuid [not null]
  updated_date    timestamp [null]
  updated_by      uuid [null]
  
  Indexes {
    (salary_basis_id, rule_id, effective_start) [unique],
    (salary_basis_id, rule_scope),
    (rule_id),
    (salary_basis_id, rule_scope, execution_order),
    (effective_start, effective_end)
  }
  
  Note: '''
  25Nov2025: Links salary basis to calculation rules
  changed 27Mar2026: ADR Option D — scopes restricted to HR-policy only
  - Defines which rules apply to entire basis (proration, rounding, annualization)
  - execution_order for TR-scope calculations only
  - SI→tax→net steps → PR engine (pay_engine.calculation_step + pay_master.statutory_rule)
  - override_params can customize rule behavior per basis
  Example: LUONG_THANG_VN basis → VN_PRORATION_2025 rule (TR scope)
           VN_PIT_2025 + VN_SI_2025 → pay_master.statutory_rule (PR scope)
  '''
}


// changed 27Mar2026: DEPRECATED — ADR Option D
// Tax calculation thuộc PR domain (pay_engine). Table này không còn thuộc TR.
// Nếu PR cần cache, sẽ tạo tại pay_engine schema.
// Giữ lại comment để tham chiếu migration.
// Table comp_core.tax_calculation_cache {
//   id              uuid [pk]
//   rule_id         uuid [ref: > comp_core.calculation_rule_def.id, not null]
//   
//   input_amount    decimal(18,4) [not null]      // Taxable income
//   output_tax      decimal(18,4) [not null]      // Calculated tax
//   output_details  jsonb [null]                  // Breakdown by bracket
//   
//   params_hash     varchar(64) [not null]        // Hash of input parameters for cache key
//   
//   calculated_at   timestamp [default:`now()`]
//   expires_at      timestamp [not null]
//   
//   Indexes {
//     (rule_id, params_hash) [unique],
//     (rule_id, input_amount),
//     (expires_at),
//     (calculated_at)
//   }
//   
//   Note: '''
//   25Nov2025: Performance optimization table — DEPRECATED 27Mar2026
//   Tax/SI calculation là PR domain → cache nếu cần sẽ ở pay_engine
//   '''
// }


//***************************************************
// * 10. COUNTRY/JURISDICTION CONFIGURATION
//       ADDED 25Nov2025: Support multi-country
// ***************************************************/

Table comp_core.country_config {
  id              uuid [pk]
  country_code    char(2) [unique, not null]   // ISO 3166-1 alpha-2
  country_name    varchar(100) [not null]
  
  currency_code   char(3) [not null]           // ISO 4217
  
  tax_system      varchar(30)                  // PROGRESSIVE | FLAT | DUAL | etc
  si_system       varchar(30)                  // MANDATORY | OPTIONAL | HYBRID
  
  standard_working_hours_per_day   int [default:8]
  standard_working_days_per_week   int [default:5]
  standard_working_days_per_month  int [default:22]
  
  config_json     jsonb [null]                 // Country-specific configurations
  
  is_active       boolean [default:true]
  
  created_date    timestamp [default:`now()`]
  created_by      uuid [not null]
  updated_date    timestamp [null]
  updated_by      uuid [null]
  
  Indexes {
    (country_code),
    (is_active)
  }
  
  Note: '''
  25Nov2025: Country-level configuration
  - Standard working hours/days per country
  - Links to tax/SI rules via country_code
  - config_json stores country-specific settings
  Example: VN → 8hrs/day, 26days/month, Progressive tax
  '''
}


// changed 06Apr2026: DEPRECATED — holiday_calendar belongs to TA team (absence.holiday_calendar is AUTHORITATIVE).
// History: should have been in Core but TA team implemented it first.
// TR reads via cross-schema soft reference: SELECT * FROM absence.holiday_calendar
//   WHERE country_code = :cc AND year = :year.
// DO NOT add new records here. DO NOT create new FKs to this table.
// Kept for backward compatibility only. Will be removed in a future version.
Table comp_core.holiday_calendar {
  id              uuid [pk]
  country_code    char(2) [ref: > comp_core.country_config.country_code, not null]
  jurisdiction    varchar(50) [null]           // State/Province if applicable
  
  year            int [not null]
  holiday_date    date [not null]
  holiday_name    varchar(200) [not null]
  holiday_type    varchar(30)                  // NATIONAL | REGIONAL | BANK | OPTIONAL
  
  is_paid         boolean [default:true]       // Paid holiday?
  ot_multiplier   decimal(4,2) [null]          // OT multiplier if work on this day (e.g., 3.0)
  
  created_date    timestamp [default:`now()`]
  created_by      uuid [not null]
  
  Indexes {
    (country_code, year, holiday_date) [unique],
    (country_code, jurisdiction, year),
    (holiday_date),
    (year)
  }
  
  Note: '''
  25Nov2025: Holiday calendar per country/jurisdiction.
  changed 06Apr2026: DEPRECATED. Use absence.holiday_calendar (authoritative source).
  - TR reads holiday data via: absence.holiday_calendar WHERE country_code + year
  - TA team owns and maintains the authoritative absence.holiday_calendar table
  - This table exists for backward compatibility only — do not add new records here
  '''
}


//***************************************************
// * 10.5 TOTAL REWARDS AGGREGATION (NEW)
//       changed 26Mar2026: G8 - Employee reward summary
// ***************************************************/

Table total_rewards.employee_reward_summary {
  id                  uuid [pk]
  employee_id         uuid [ref: > employment.employee.id, not null]
  eligibility_profile_id uuid [null]                               // centralized eligibility that granted this reward

  reward_type         varchar(30) [not null]                       // LEAVE | BENEFIT | COMP_PLAN | BONUS | PAYROLL_ELEMENT | PERK
  reward_source       varchar(50) [not null]                       // schema.table reference (e.g., 'absence.leave_type')
  reward_entity_id    uuid [not null]                              // FK dynamic to source entity
  reward_entity_code  varchar(50) [null]                           // human-readable code
  reward_entity_name  varchar(255) [null]                          // display name

  status              varchar(20) [not null]                       // ACTIVE | FUTURE | EXPIRED | WAIVED

  effective_start     date [not null]
  effective_end       date [null]

  calculated_value    decimal(18,4) [null]                         // monetary value if applicable
  currency            char(3) [null]

  last_evaluated_at   timestamp [not null]
  metadata            jsonb [null]
  created_at          timestamp [default:`now()`]
  updated_at          timestamp [null]

  Indexes {
    (employee_id, reward_type, status)
    (employee_id, eligibility_profile_id)
    (reward_type, reward_entity_id)
    (status, effective_start)
  }

  Note: '''
    changed 26Mar2026: G8 - Aggregation table for Total Rewards per employee.
    Materialized summary: updated when eligibility changes, enrollment changes, or comp cycles complete.
    Provides single query point: "What rewards does employee X have?"
    Populated by background process that evaluates eligibility across all modules.
  '''
}

// as request by a Trân 27/3/2026
// =============================================================
//  SCHEMA: compensation – Compensation Basis (CompensationBasis Ontology)
// =============================================================
// changed 06feb2026: NEW schema for CompensationBasis entity with flexible component lines

Table compensation.basis {                     // mức lương hiệu lực (header)
  id                      uuid        [pk, default: `gen_random_uuid()`]
  work_relationship_id    uuid        [ref: > employment.work_relationship.id, not null]  // link to WorkRelationship
  assignment_id           uuid        [ref: > employment.assignment.id, null]              // changed 26Mar2026: G1 - link to specific assignment (nullable for backward compat)
  
  // Effective Dating (SCD Type-2)
  effective_start_date    date        [not null]                        // ngày bắt đầu hiệu lực
  effective_end_date      date        [null]                            // ngày kết thúc (null = current)
  is_current_flag         boolean     [default: false]                  // cờ bản ghi hiện tại
  
  // Core Salary Basis
  basis_amount            decimal(15,2) [not null]                      // lương cơ bản (operational)
  currency_code           char(3)     [default: 'VND']                  // mã tiền tệ (ISO 4217)
  frequency_code          varchar(20) [default: 'MONTHLY']              // MONTHLY, HOURLY, ANNUALLY, DAILY, PER_UNIT  // changed 26Mar2026: G2 - thêm PER_UNIT cho piece-rate
  annualization_factor    decimal(6,2) [null]                           // factor quy năm
  annual_equivalent       decimal(15,2) [null]                          // lương quy năm (calculated)
  
  // changed 26Mar2026: G2 - Piece-Rate / Output-Based Pay Support
  output_unit_code        varchar(30) [null]                            // đơn vị sản phẩm: PIECE, ARTICLE, TEACHING_HOUR, GARMENT (common.code_list(OUTPUT_UNIT))
  unit_rate_amount        decimal(15,4) [null]                          // rate per unit (VD: 50,000 VND/piece)
  guaranteed_minimum      decimal(15,2) [null]                          // lương tối thiểu đảm bảo khi output-based < minimum
  
  // Classification
  basis_type_code         varchar(30) [not null, default: 'OPERATIONAL_BASE']  // LEGAL_BASE | OPERATIONAL_BASE | MARKET_ADJUSTED
  // changed 23Apr2026: source_code = WHO/WHAT triggered creation (TRIGGER)
  source_code             varchar(30) [not null, default: 'CONTRACT']  // CONTRACT | MANUAL_ADJUST | COMP_CYCLE | SYSTEM_AUTO
  // changed 23Apr2026: reason_code = WHY salary changed (business reason)
  reason_code             varchar(30) [null]                           // HIRE | PROBATION_END | ANNUAL_REVIEW | PROMOTION | TRANSFER | MARKET_ADJUST | CORRECTION
  
  // Adjustment Tracking
  adjustment_amount       decimal(15,2) [null]                          // delta từ record trước
  adjustment_percentage   decimal(5,2) [null]                           // % thay đổi
  previous_basis_id       uuid        [ref: > compensation.basis.id, null]  // SCD chain (self-ref)
  change_event_id         uuid        [null]  // changed 23Apr2026: link to comp cycle event (for batch changes via COMP_CYCLE)
  
  // References
  contract_id             uuid        [ref: > employment.contract.id, null]  // source contract; MUST NOT NULL when basis_type_code = LEGAL_BASE (app-layer)
  // changed 03Apr2026: salary_basis_id links to approved template for this employee.
  // Nullable for legacy records only. New records from UI must have salary_basis_id populated.
  // See: compensation-basis-design.md §3 (Onboard Flow), §6 (Auto-Expiry)
  salary_basis_id         uuid        [null, ref: > comp_core.salary_basis.id]  // changed 03Apr2026
  
  // Approval Workflow
  approval_status         varchar(20) [null]                            // PENDING, APPROVED, REJECTED
  approved_by             uuid        [ref: > person.worker.id, null]   // approver
  approval_date           timestamp   [null]
  next_review_date        date        [null]
  
  // VN Specific
  social_insurance_basis  decimal(15,2) [null]                          // mức đóng BHXH (nếu khác basis_amount)
  regional_min_wage_zone  varchar(10) [null]                            // ZONE_I, ZONE_II, ZONE_III, ZONE_IV
  
  // Flexible Component Lines (aggregated — synced by app-layer transaction)
  // changed 23Apr2026: removed has_component_lines (redundant with component_line_count > 0)
  // changed 23Apr2026: removed total_gross_amount (computed at app layer: basis_amount + total_allowance_amount)
  total_allowance_amount  decimal(15,2) [default: 0]  // SUM(basis_line.amount) WHERE is_current_flag = true
  component_line_count    int         [default: 0]    // COUNT(basis_line) WHERE is_current_flag = true
  
  // Notes & Status
  notes                   text        [null]
  status_code             varchar(30) [not null, default: 'DRAFT']      // DRAFT, PENDING_APPROVAL, ACTIVE, FUTURE, SUPERSEDED, CANCELLED
  
  // Audit
  created_at              timestamp   [default: `now()`]
  updated_at              timestamp   [null]
  created_by              uuid        [ref: > person.worker.id, null]
  updated_by              uuid        [ref: > person.worker.id, null]
  
  Indexes {
    // changed 23Apr2026: LEGAL_BASE và OPERATIONAL_BASE có thể đồng thời active trên cùng employee
    // → unique constraint phải bao gồm basis_type_code để allow 2 concurrent active basis
    (work_relationship_id, basis_type_code, effective_start_date) [unique]
    (work_relationship_id, basis_type_code, is_current_flag) [name: 'idx_basis_current', note: 'WHERE is_current_flag = true']
    (status_code, is_current_flag)
    (previous_basis_id)  // SCD chain lookup
    (change_event_id)    // changed 23Apr2026: batch comp cycle lookup
  }
  
  Note: '''
    changed 06feb2026: NEW — CompensationBasis, SCD Type-2 header.
    changed 26Mar2026: G1 — assignment_id (multi-assignment support).
    changed 26Mar2026: G2 — piece-rate fields (output_unit_code, unit_rate_amount, guaranteed_minimum).
    changed 03Apr2026: salary_basis_id FK + eligibility integration.
    changed 23Apr2026: concurrent basis support (LEGAL_BASE + OPERATIONAL_BASE), removed redundant fields,
      clarified source_code/reason_code semantics, added change_event_id.
    
    Design doc: compensation-basis-design.md
    (Onboard flow, salary change flow, auto-expiry, concurrent basis types, aggregation sync, mandatory components)
  '''
}

Table compensation.basis_line {                // chi tiết phụ cấp cố định (flexible lines)
  id                      uuid        [pk, default: `gen_random_uuid()`]
  basis_id                uuid        [ref: > compensation.basis.id, not null]  // header
  
  // Component Link — changed 03Apr2026: Thêm pay_component_def_id (NOT NULL, FK enforced)
  // RATIONALE: basis_line phải tham chiếu về pay_component_def để có:
  //   - tax_treatment / tax_exempt_threshold (dùng để tính thuế TNCN)
  //   - is_subject_to_si / si_calculation_basis (dùng để tính BHXH)
  //   - calculation_method / proration_method (dùng khi payroll tính toán)
  // Không có FK → line không tham gia được vào payroll engine → vô nghĩa.
  //
  // CONSTRAINT (app-layer):
  //   pay_component_def_id MUST exist in comp_core.salary_basis_component_map
  //   WHERE salary_basis_id = (SELECT salary_basis_id FROM compensation.basis WHERE id = basis_id)
  //   Tức là: chỉ được dùng component đã được cấu hình trong salary_basis của parent basis.
  //
  // REMOVED 03Apr2026: component_name varchar (ad-hoc free-text) — bị xóa vì:
  //   - Nếu không link về pay_component_def → không có calc rules → không tham gia payroll.
  //   - Mọi component phải được định nghĩa trước trong pay_component_def.
  //   - Tên component dùng pay_component_def.name thay thế.
  pay_component_def_id    uuid        [not null, ref: > comp_core.pay_component_def.id]  // changed 03Apr2026: FK NOT NULL
  
  // Component Type — changed 03Apr2026: Xóa 'OTHER'
  // Tất cả component phải được typed và link về pay_component_def.
  // Lookup: common.code_list(COMP_COMPONENT_TYPE)
  // Valid codes: MEAL | HOUSING | TRANSPORTATION | RESPONSIBILITY | SENIORITY | TOXICITY | PHONE
  // REMOVED: OTHER — nếu cần loại phụ cấp mới, thêm pay_component_def record + enum code trước.
  component_type_code     varchar(50) [not null]  // MEAL | HOUSING | TRANSPORTATION | RESPONSIBILITY | SENIORITY | TOXICITY | PHONE
                                                   // Must match pay_component_def.component_type = 'ALLOWANCE'
  
  // Amount
  amount                  decimal(15,2) [not null]                      // số tiền phụ cấp
  currency_code           char(3)     [default: 'VND']
  
  // Source
  source_code             varchar(30) [not null, default: 'FIXED']      // FIXED = chốt cứng riêng, OVERRIDE = override từ plan
                                                                         // (Phụ cấp tính từ plan sẽ KHÔNG ở đây, do Compensation Plan xử lý)
  reason_code             varchar(50) [null]                            // lý do phụ cấp (HIRE, ROLE_CHANGE, SPECIAL, etc.)
  
  // Effective Dating
  effective_start_date    date        [not null]                        // ngày bắt đầu có hiệu lực
  effective_end_date      date        [null]                            // ngày kết thúc (null = ongoing)
  is_current_flag         boolean     [default: true]
  
  // Reference
  reference_id            uuid        [null]                            // optional reference (e.g., job_id, position_id if based on role)
  reference_type          varchar(30) [null]                            // JOB, POSITION, LOCATION, etc.
  
  // Notes & Audit
  notes                   text        [null]
  metadata                jsonb       [null]                            // additional info
  created_at              timestamp   [default: `now()`]
  updated_at              timestamp   [null]
  created_by              uuid        [ref: > person.worker.id, null]
  updated_by              uuid        [ref: > person.worker.id, null]
  
  Indexes {
    (basis_id, pay_component_def_id) [unique]                          // changed 03Apr2026: unique per basis + component_def (replaced component_type_code)
    (basis_id, pay_component_def_id, effective_start_date) [unique]    // changed 03Apr2026: unique per basis + def + date
    (basis_id, is_current_flag)                                         // current lines per basis
    (pay_component_def_id, is_current_flag)                            // changed 03Apr2026: reporting by component def
  }

  Note: '''
    changed 03Apr2026: Structural fix — Mandatory pay_component_def_id.
    basis_line.pay_component_def_id MUST exist in salary_basis_component_map
    for the salary_basis_id of the parent compensation.basis.
    Enforcement: CompensationBasisService.addLine() + payroll pre-run validation.
    See: compensation-basis-design.md §9 (basis_line Constraint), §8 (Mandatory Component Enforcement)
  '''
}

//***************************************************
// * 11. RELATIONSHIPS & ADDITIONAL NOTES
// ***************************************************/

Note comp_core_relationships {
  '''
  KEY RELATIONSHIPS (Updated 25Nov2025):
  
  1. CALCULATION FLOW:
     salary_basis 
       → basis_calculation_rule → calculation_rule_def (tax, SI, rounding rules)
       → salary_basis_component_map 
         → pay_component_def 
           → component_calculation_rule → calculation_rule_def (component formulas, OT rules)
  
  2. EMPLOYEE COMPENSATION:
     employee_comp_snapshot 
       → salary_basis_id → salary_basis
       → component_id → pay_component_def
       → components JSON array
  
  3. COMPENSATION CYCLES:
     comp_plan → comp_cycle → comp_adjustment → employee_comp_snapshot (creates new snapshot)
  
  4. VERSIONING (SCD-2):
     - grade_v: version_number + previous_version_id + is_current_version
     - pay_range: effective_start/effective_end (no version chain yet)
     - calculation_rule_def: version_number + previous_version_id + is_current_version
     - employee_comp_snapshot: effective_start/effective_end
  
  5. MULTI-COUNTRY SUPPORT (NEW 25Nov2025):
     country_config 
       → calculation_rule_def (via country_code)
       → holiday_calendar
  
  6. RULE EXECUTION ORDER:
     basis_calculation_rule.execution_order defines:
       1 = Proration rules (calculate prorated amounts)
       2 = Component calculations (formulas, OT)
       3 = Gross salary sum
       4 = Social insurance deductions
       5 = Tax calculations (PIT)
       6 = Net salary calculation
  
  7. CALCULATION RULE EXAMPLES:
     VN_PIT_2025:
       - Progressive tax with 7 brackets
       - Personal deduction: 15.5M VND/month
       - Dependent deduction: 6.2M VND/person/month
     
     VN_SI_2025:
       - Employee: 8% SI + 1.5% HI + 1% UI = 10.5%
       - Employer: 14% SI + 3% HI + 1% UI + 0.5% LA = 18.5%
       - Min: 2.34M, Max: 46.8M VND
     
     VN_OT_MULT_2019:
       - Weekday normal: 1.5×
       - Weekday night: 1.95×
       - Weekend: 2.0×
       - Holiday: 3.0×
  
  8. AUDIT TRAIL:
     tr_audit.audit_log captures all changes with:
       - Before/after values
       - User/timestamp
       - Change reason
  '''
}


//***************************************************
// * 12. PERFORMANCE MANAGEMENT
//        ADDED 23Apr2026: Performance sub-module
//
//        Scope:
//          - KPI Definition (master, SCD2)
//          - Rating Scale + Level (master config)
//          - Review Cycle (transaction — một kỳ đánh giá)
//          - KPI Assignment (giao KPI cho nhân viên trong cycle)
//          - KPI Result (kết quả thực tế)
//          - Employee Review (tổng kết overall rating)
//
//        Domain Boundary:
//          - performance.* owns: KPI definition, target setting, result tracking, overall rating
//          - comp_incentive.* owns: bonus allocation (đọc performance result làm INPUT)
//          - TA / Absence: attendance data là input cho KPI — không owned ở đây
//
//        SCD2 decision:
//          - kpi_def_v    : CÓ SCD2 — KPI definition thay đổi theo năm
//          - rating_scale : KHÔNG SCD2 — tạo scale mới khi đổi, không version
//          - review_cycle : KHÔNG SCD2 — sự kiện có thời gian xác định
//          - kpi_assignment / kpi_result / employee_review: KHÔNG SCD2 — transaction records
// ***************************************************/


// ─────────────────────────────────────────────────
// 12.1  KPI Definition  (Master Data – CÓ SCD2)
//
//       Tại sao SCD2:
//         KPI có thể thay đổi unit_of_measure, calculation_method, hoặc category
//         qua các năm. Lịch sử cần được giữ để đối chiếu kết quả cũ với đúng
//         definition tại thời điểm đó (VD: Revenue KPI năm 2024 tính theo VND,
//         năm 2025 đổi sang USD — cần version riêng biệt).
// ─────────────────────────────────────────────────

Table performance.kpi_def_v {
  id                  uuid          [pk]
  kpi_code            varchar(50)   [not null]
  // Stable identifier across versions: REVENUE_GROWTH, CSAT_SCORE, HEADCOUNT_RATIO
  name                varchar(255)  [not null]
  description         text          [null]

  // Phân loại KPI theo Balanced Scorecard framework
  kpi_category        varchar(30)   [not null]
  // FINANCIAL     = doanh thu, lợi nhuận, chi phí, ROI
  // CUSTOMER      = NPS, CSAT, churn rate, retention
  // OPERATIONAL   = năng suất, chất lượng quy trình, SLA
  // LEARNING      = đào tạo, phát triển năng lực, certification
  // PEOPLE        = turnover, engagement score, headcount
  // STRATEGIC     = OKR-level, initiative completion rate

  kpi_type            varchar(20)   [not null]
  // QUANTITATIVE  = đo bằng số tuyệt đối (doanh thu, số ticket)
  // QUALITATIVE   = đánh giá bằng thang điểm (peer review score)
  // BINARY        = hoàn thành / không hoàn thành (project delivery)

  unit_of_measure     varchar(50)   [null]
  // VND, USD, %, SCORE, COUNT, DAYS, NPS_POINT, TICKET

  calculation_method  varchar(30)   [null]
  // SUM_PERIOD    = cộng dồn cả kỳ (doanh thu tháng, số tickets giải quyết)
  // AVERAGE       = trung bình kỳ (CSAT trung bình, avg response time)
  // LATEST        = giá trị tại thời điểm cuối kỳ (headcount ngày 31)
  // RATE          = tỷ lệ so với target (actual / target × 100)

  aggregation_scope   varchar(20)   [null]
  // INDIVIDUAL    = KPI đo riêng cho từng cá nhân
  // TEAM          = KPI đo cho team, phân bổ xuống thành viên
  // DEPARTMENT    = KPI đo cho phòng ban
  // COMPANY       = KPI toàn công ty (cascade xuống mọi level)

  // SCD-2 versioning
  effective_start     date          [not null]
  effective_end       date          [null]             // null = version đang hiệu lực
  version_number      int           [default: 1]
  previous_version_id uuid          [ref: > performance.kpi_def_v.id, null]
  is_current_version  boolean       [default: true]

  is_active           boolean       [default: true]

  Indexes {
    (kpi_code, effective_start)
    (kpi_code) [unique, where: "is_current_version = true"]
    (kpi_category)
    (kpi_type)
    (is_current_version) [where: "is_current_version = true"]
    (effective_start, effective_end)
  }

  Note: '''
    ADDED 23Apr2026: KPI Definition với SCD-2.
    kpi_code là stable identifier — không đổi qua các version.
    previous_version_id tạo version chain để traceability.
    Khi tạo version mới:
      1. Set is_current_version = false, effective_end = today trên record cũ
      2. Tạo record mới với version_number + 1, previous_version_id = id cũ
      3. kpi_assignment.kpi_def_id trỏ về version hiệu lực tại assign-time (frozen)
  '''
}


// ─────────────────────────────────────────────────
// 12.2  Rating Scale  (Master Data – KHÔNG SCD2)
//
//       Thang điểm dùng để đánh giá KPI và overall performance.
//       Không SCD2: nếu thay đổi thang điểm → tạo scale mới (code mới).
// ─────────────────────────────────────────────────

Table performance.rating_scale {
  id                  uuid          [pk]
  code                varchar(50)   [unique, not null]  // SCALE_1_5, SCALE_ABCD, SCALE_3PT
  name                varchar(200)  [not null]

  scale_type          varchar(20)   [not null]
  // NUMERIC       = thang số nguyên hoặc thập phân (1.0 – 5.0)
  // LETTER        = thang chữ cái (A, B, C, D)
  // LABEL         = thang nhãn (Exceeds Expectations, Meets, Below)

  effective_start     date          [not null]
  effective_end       date          [null]
  is_active           boolean       [default: true]

  Indexes {
    (code)
    (is_active) [where: "is_active = true"]
  }
}


// Chi tiết từng mức trong thang điểm
Table performance.rating_scale_level {
  id                  uuid          [pk]
  scale_id            uuid          [ref: > performance.rating_scale.id, not null]
  level_order         int           [not null]    // thứ tự (1 = thấp nhất)
  level_code          varchar(20)   [not null]    // 1/2/3/4/5 hoặc A/B/C/D
  level_name          varchar(100)  [not null]    // Outstanding, Exceeds Expectations, Meets...
  numeric_value       decimal(4,2)  [null]        // giá trị số để tính trung bình có trọng số
  description         text          [null]        // tiêu chí mô tả mức điểm này

  Indexes {
    (scale_id, level_order) [unique]
    (scale_id, level_code)  [unique]
  }

  Note: '''
    ADDED 23Apr2026.
    numeric_value dùng để tính weighted_kpi_score trong employee_review:
      weighted_kpi_score = Σ(level.numeric_value × assignment.weight_pct) / 100
    Ví dụ thang 1-5:
      level_code=1, level_name=Unsatisfactory,       numeric_value=1.0
      level_code=3, level_name=Meets Expectations,   numeric_value=3.0
      level_code=5, level_name=Outstanding,          numeric_value=5.0
  '''
}


// ─────────────────────────────────────────────────
// 12.3  Review Cycle  (Transaction – KHÔNG SCD2)
//
//       Một kỳ đánh giá cụ thể: Annual 2025, Q1 2026, Mid-Year 2026...
//       Là "container" cho toàn bộ hoạt động review trong một giai đoạn.
// ─────────────────────────────────────────────────

Table performance.review_cycle {
  id                  uuid          [pk]
  code                varchar(50)   [unique, not null]  // ANNUAL_2025, Q1_2026, MID_YEAR_2026
  name                varchar(255)  [not null]

  cycle_type          varchar(20)   [not null]
  // ANNUAL        = đánh giá năm
  // SEMI_ANNUAL   = đánh giá 6 tháng (mid-year + year-end)
  // QUARTERLY     = đánh giá quý
  // PROJECT_BASED = đánh giá theo dự án/milestone

  period_start        date          [not null]    // ngày bắt đầu kỳ KPI được đo
  period_end          date          [not null]    // ngày kết thúc kỳ KPI được đo

  // Mốc thời gian quy trình review
  target_setting_deadline  date     [null]        // hạn chót giao KPI target
  self_review_deadline     date     [null]        // hạn chót nhân viên tự đánh giá
  manager_review_deadline  date     [null]        // hạn chót manager đánh giá
  calibration_deadline     date     [null]        // hạn chót calibration session

  status              varchar(20)   [not null, default: 'DRAFT']
  // DRAFT → OPEN → IN_PROGRESS → CALIBRATION → COMPLETED → CLOSED

  // Scoping — ai tham gia cycle này
  legal_entity_id          uuid     [null]        // null = toàn công ty
  eligibility_profile_id   uuid     [null, ref: > eligibility.eligibility_profile.id]
  // null = tất cả employee; not null = chỉ employee trong profile

  rating_scale_id     uuid          [ref: > performance.rating_scale.id, null]

  Indexes {
    (code)
    (cycle_type, period_start)
    (status)
    (period_start, period_end)
    (legal_entity_id)
    (eligibility_profile_id)
  }

  Note: '''
    ADDED 23Apr2026: Review Cycle — khung tổ chức cho một đợt đánh giá.
    Không SCD2: cycle là sự kiện có thời gian xác định.
    Sau khi status = IN_PROGRESS → không được thay đổi period_start/period_end.
    eligibility_profile_id: consistent với pattern toàn hệ thống
      (comp_plan, bonus_plan, schedule_assignment).
  '''
}


// ─────────────────────────────────────────────────
// 12.4  KPI Assignment  (Transaction – KHÔNG SCD2)
//
//       Giao một KPI cụ thể cho nhân viên trong một review cycle.
//       Là "hợp đồng" KPI: ai phải đạt gì, đo bằng gì, trọng số bao nhiêu.
//       LOCKED khi cycle chuyển IN_PROGRESS — không được sửa target sau đó.
// ─────────────────────────────────────────────────

Table performance.kpi_assignment {
  id                  uuid          [pk]
  cycle_id            uuid          [ref: > performance.review_cycle.id, not null]
  employee_id         uuid          [ref: > employment.employee.id, not null]
  kpi_def_id          uuid          [ref: > performance.kpi_def_v.id, not null]
  // Trỏ về version hiệu lực tại thời điểm giao KPI — FROZEN tại assign-time

  // Target
  target_value        decimal(18,4) [not null]    // mục tiêu cần đạt
  target_currency     char(3)       [null]        // chỉ điền nếu unit_of_measure là tiền tệ
  weight_pct          decimal(5,2)  [null]
  // % trọng số — tổng tất cả KPI của 1 employee trong 1 cycle = 100%

  stretch_target_value decimal(18,4) [null]       // target thêm cho high-performer

  assigned_by_id      uuid          [ref: > employment.employee.id, null]

  assignment_status   varchar(20)   [not null, default: 'DRAFT']
  // DRAFT → PENDING_CONFIRM → CONFIRMED → LOCKED

  // Cascade — BSC model: COMPANY → DEPARTMENT → TEAM → INDIVIDUAL
  parent_assignment_id uuid         [ref: > performance.kpi_assignment.id, null]
  // null = KPI độc lập; not null = cascade từ team/dept assignment

  Indexes {
    (cycle_id, employee_id)
    (cycle_id, employee_id, kpi_def_id) [unique]
    (employee_id)
    (kpi_def_id)
    (assignment_status)
    (parent_assignment_id)
    (cycle_id, assignment_status)
  }

  Note: '''
    ADDED 23Apr2026: KPI Assignment — contract KPI giữa manager và nhân viên.
    Không SCD2: update trực tiếp nếu target thay đổi trước khi LOCKED.
    Sau khi cycle.status = IN_PROGRESS → assignment_status = LOCKED.
    App-layer: Σ(weight_pct) cho tất cả assignments của 1 employee trong 1 cycle = 100%.
    Cascade: DEPARTMENT KPI (parent) → INDIVIDUAL assignments (children).
  '''
}


// ─────────────────────────────────────────────────
// 12.5  KPI Result  (Transaction – KHÔNG SCD2)
//
//       Kết quả thực tế của một KPI assignment.
//       CHECK_IN: cập nhật tiến độ giữa kỳ (nhiều records).
//       FINAL: kết quả chính thức cuối kỳ (unique per assignment).
// ─────────────────────────────────────────────────

Table performance.kpi_result {
  id                  uuid          [pk]
  assignment_id       uuid          [ref: > performance.kpi_assignment.id, not null]

  result_type         varchar(20)   [not null]
  // CHECK_IN      = cập nhật tiến độ giữa kỳ (không ảnh hưởng final rating)
  // FINAL         = kết quả cuối kỳ chính thức

  measurement_date    date          [not null]
  actual_value        decimal(18,4) [not null]    // giá trị thực tế
  actual_currency     char(3)       [null]

  achievement_rate    decimal(7,4)  [null]
  // = (actual_value / target_value) × 100
  // Lưu sẵn để aggregate nhanh — không tính on-the-fly

  kpi_rating_code     varchar(20)   [null]        // level_code từ rating_scale_level
  kpi_rating_numeric  decimal(4,2)  [null]        // numeric_value tương ứng

  note                text          [null]
  submitted_by_id     uuid          [ref: > employment.employee.id, null]

  Indexes {
    (assignment_id, result_type)
    (assignment_id) [unique, where: "result_type = 'FINAL'"]
    (measurement_date)
    (result_type)
  }

  Note: '''
    ADDED 23Apr2026: KPI Result — fact record kết quả thực tế.
    Không SCD2: fact record, không thay đổi.
    CHECK_IN: nhiều records per assignment. FINAL: unique constraint.
    achievement_rate được store (không tính on-the-fly) để tổng hợp nhanh.
  '''
}


// ─────────────────────────────────────────────────
// 12.6  Employee Review  (Transaction – KHÔNG SCD2)
//
//       Tổng kết đánh giá tổng thể của nhân viên trong một review cycle.
//       Aggregate từ tất cả KPI results + judgment của manager + calibration.
//       Overall rating là OUTPUT quan trọng nhất — ảnh hưởng trực tiếp đến
//       bonus allocation, merit increase, và succession planning.
// ─────────────────────────────────────────────────

Table performance.employee_review {
  id                  uuid          [pk]
  cycle_id            uuid          [ref: > performance.review_cycle.id, not null]
  employee_id         uuid          [ref: > employment.employee.id, not null]

  // KPI Score tổng hợp — tính từ kpi_result
  weighted_kpi_score  decimal(5,2)  [null]
  // = Σ(kpi_result.kpi_rating_numeric × kpi_assignment.weight_pct) / 100

  // Overall Rating — do manager quyết định (có thể khác weighted_kpi_score)
  overall_rating_code     varchar(20) [null]
  overall_rating_numeric  decimal(4,2) [null]
  rating_scale_id         uuid         [ref: > performance.rating_scale.id, null]

  // Kết quả sau calibration (HR/leadership adjust)
  calibrated_rating_code     varchar(20) [null]
  calibrated_rating_numeric  decimal(4,2) [null]
  calibration_note           text        [null]

  // Review Status Lifecycle
  review_status       varchar(20)   [not null, default: 'PENDING_SELF']
  // PENDING_SELF    → nhân viên chưa tự đánh giá
  // SELF_DONE       → nhân viên đã submit self-assessment
  // PENDING_MANAGER → chờ manager complete review
  // MANAGER_DONE    → manager đã submit rating + feedback
  // CALIBRATION     → HR đang calibrate kết quả
  // FINAL_APPROVED  → kết quả đã được phê duyệt chính thức
  // ACKNOWLEDGED    → nhân viên đã xác nhận biết kết quả

  // Self-review
  self_rating_code    varchar(20)   [null]
  self_assessment     text          [null]

  // Manager review
  manager_id          uuid          [ref: > employment.employee.id, null]
  manager_feedback    text          [null]

  approved_by_id      uuid          [ref: > employment.employee.id, null]
  approved_date       date          [null]

  // Performance Tier — segment nhân viên để dùng trong compensation planning
  performance_tier    varchar(20)   [null]
  // HIGH_PERFORMER    = top ~20%, eligible cho high bonus multiplier
  // SOLID_PERFORMER   = standard, standard bonus
  // NEEDS_IMPROVEMENT = đang cải thiện, bonus giảm hoặc không có
  // UNDERPERFORMER    = cần PIP, không eligible cho bonus
  // Derived từ calibrated_rating (hoặc overall_rating nếu không có calibration)
  // Denormalized để query nhanh trong compensation planning

  Indexes {
    (cycle_id, employee_id) [unique]
    (employee_id)
    (review_status)
    (cycle_id, review_status)
    (overall_rating_code)
    (performance_tier)
    (manager_id)
    (cycle_id, performance_tier)
  }

  Note: '''
    ADDED 23Apr2026: Employee Review — tổng kết đánh giá tổng thể.
    Không SCD2: transaction record cho cycle cụ thể.

    overall_rating vs calibrated_rating:
      overall_rating   : manager đặt trực tiếp sau khi xem KPI scores
      calibrated_rating: HR điều chỉnh sau calibration session (có thể giữ nguyên)

    weighted_kpi_score vs overall_rating:
      weighted_kpi_score: tính toán thuần túy từ số liệu KPI
      overall_rating    : judgment call của manager (context, behavior, contribution)
      Hai giá trị này CÓ THỂ KHÁC NHAU — đây là design intent.

    performance_tier: denormalized từ calibrated/overall rating.
    Dùng để query nhanh trong TR domain:
      "Danh sách HIGH_PERFORMER trong cycle để tính bonus multiplier"

    CROSS-MODULE LINK (TR → Performance):
      comp_incentive.bonus_allocation.performance_review_id → performance.employee_review.id
      bonus_plan.formula_json reference performance_tier để tính multiplier:
        {
          "HIGH_PERFORMER":     { "multiplier": 1.5 },
          "SOLID_PERFORMER":    { "multiplier": 1.0 },
          "NEEDS_IMPROVEMENT":  { "multiplier": 0.5 },
          "UNDERPERFORMER":     { "multiplier": 0.0 }
        }
  '''
}


// ─────────────────────────────────────────────────
// 12.7  Cross-Module Link: bonus_allocation ↔ employee_review
//
//       Field performance_review_id được ADD vào comp_incentive.bonus_allocation.
//       Documented ở đây để cross-reference rõ ràng.
//
//       Semantics:
//         null     = bonus không dựa vào performance (retention, spot, project bonus)
//         not null = performance-based bonus; amount phụ thuộc vào performance_tier
//
//       Lookup pattern cho compensation planning:
//         SELECT ba.employee_id, ba.proposed_amount,
//                er.performance_tier, er.calibrated_rating_numeric
//         FROM comp_incentive.bonus_allocation ba
//         JOIN performance.employee_review er
//           ON er.id = ba.performance_review_id
//         WHERE ba.pool_id = :pool_id
//           AND er.performance_tier = 'HIGH_PERFORMER'
// ─────────────────────────────────────────────────
