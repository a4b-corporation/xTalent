/*----------- 8. Shift Swap Request (NEW) -----------------------*/
// [v5] NEW TABLE: Workflow for shift swapping
Table ta.shift_swap_request {
  id                uuid [pk]
  requestor_id      uuid [ref: > employment.employee.id]
  target_worker_id  uuid [ref: > employment.employee.id]
  
  requestor_shift_id uuid [ref: > ta.shift.id]
  target_shift_id    uuid [ref: > ta.shift.id]
  
  request_date      timestamptz [default:`now()`]
  reason            text [null]
  
  status_code       varchar(30) [default:'PENDING'] // PENDING, ACCEPTED_BY_TARGET, REJECTED_BY_TARGET, APPROVED, REJECTED, CANCELLED
  
  target_response   varchar(20) [default:'PENDING'] // PENDING, ACCEPTED, REJECTED
  target_response_at timestamptz [null]
  
  manager_approval  varchar(20) [default:'PENDING'] // PENDING, APPROVED, REJECTED
  approved_by       uuid [ref: > employment.employee.id, null]
  approved_at       timestamptz [null]
  rejection_reason  text [null]
  
  metadata          jsonb
  created_at        timestamptz [default:`now()`]
  updated_at        timestamptz [null]
  
  Indexes { 
    (requestor_id)
    (target_worker_id)
    (status_code)
  }
}

// 2025-12-01 NEW: Shift swap workflow


/*----------- 9. Shift Bid (NEW) --------------------------------*/
// [v5] NEW TABLE: Workflow for open shift bidding
Table ta.shift_bid {
  id                uuid [pk]
  worker_id         uuid [ref: > employment.employee.id]
  shift_id          uuid [ref: > ta.shift.id]
  
  bid_date          timestamptz [default:`now()`]
  priority          int [null]                  // worker's priority ranking
  reason            text [null]
  
  status_code       varchar(20) [default:'PENDING'] // PENDING, ACCEPTED, REJECTED, EXPIRED
  
  assigned_at       timestamptz [null]
  expires_at        timestamptz [null]
  
  metadata          jsonb
  created_at        timestamptz [default:`now()`]
  
  Indexes { 
    (worker_id, shift_id) [unique]
    (shift_id, status_code)
  }
}

// 2025-12-01 NEW: Shift bidding for open shifts


// COMMENTED OUT 27Mar2026: Đã merge vào ta.eval_rule ở phần trên.
// /*----------- 10. Overtime Rule (Nâng cấp eval_rule) -----------*/
// [DUPLICATE] This table overlaps with 'ta.eval_rule' defined above.
// Table ta.overtime_rule_DUPLICATE { ... }


/*----------- 11. Overtime Request (NEW) ------------------------*/
// [v5] NEW TABLE: Pre-approval workflow for overtime
// 27Mar2026 ENHANCED: OT type classification (VLC Art. 98), caps (VLC Art. 107), comp-time election (Change 7)
Table ta.overtime_request {
  id                uuid [pk]
  worker_id         uuid [ref: > employment.employee.id]
  
  request_date      timestamptz [default:`now()`]  // 27Mar2026: changed timestamp → timestamptz (Change 10)
  planned_date      date
  estimated_hours   decimal(5,2)
  reason            text
  
  project_id        uuid [null]
  
  // 27Mar2026 NEW: OT type classification (Change 7, VLC Art. 98)
  ot_type           varchar(20) [null]           // See Enum overtime_type: WEEKDAY | WEEKEND | PUBLIC_HOLIDAY
  ot_rate           decimal(4,2) [null]          // 1.5 (weekday) | 2.0 (weekend) | 3.0 (holiday) per VLC Art. 98
  
  // 27Mar2026 NEW: Comp time election (Change 7)
  comp_time_elected boolean [default:false]      // true = employee takes comp-time off instead of OT pay
  
  // 27Mar2026 NEW: VLC Art. 107 caps — for validation and audit
  // Note: These are snapshot values at request time. Actual cap enforcement is done by service layer.
  daily_ot_cap_hours   decimal(4,2) [default:4]  // VLC Art. 107: max 4h/day
  monthly_ot_cap_hours decimal(6,2) [default:40] // VLC Art. 107: max 40h/month
  annual_ot_cap_hours  decimal(6,2) [default:300] // VLC Art. 107: max 300h/year (with consent)
  
  status_code       varchar(20) [default:'PENDING'] // PENDING, APPROVED, REJECTED, CANCELLED
  
  approved_by       uuid [ref: > employment.employee.id, null]
  approved_at       timestamptz [null]              // 27Mar2026: changed timestamp → timestamptz (Change 10)
  rejection_reason  text [null]
  
  actual_hours      decimal(5,2) [null]         // filled after work completed
  
  metadata          jsonb
  created_at        timestamptz [default:`now()`]   // 27Mar2026: changed timestamp → timestamptz (Change 10)
  updated_at        timestamptz [null]              // 27Mar2026: changed timestamp → timestamptz (Change 10)
  
  Indexes { 
    (worker_id, planned_date)
    (status_code)
  }
  
  Note: 'VLC Art. 107: OT caps — daily=4h, monthly=40h, annual=200-300h (300h requires written consent). VLC Art. 98: OT rates — weekday=150%, weekend=200%, public_holiday=300%.'
}

// 2025-12-01 NEW: Pre-approval for overtime
// 27Mar2026 ENHANCED: Added ot_type, ot_rate, comp_time_elected, VLC caps


// COMMENTED OUT 27Mar2026: Đã merge vào ta.eval_result ở phần trên.
// /*----------- 12. Overtime Calculation (Nâng cấp eval_result) --*/
// [DUPLICATE] This table overlaps with 'ta.eval_result' defined above.
// Table ta.overtime_calculation_DUPLICATE { ... }


//===============================================================
//  PHẦN 2: ABSENCE MANAGEMENT (Absence Schema)
//  Giữ nguyên thiết kế v4, chỉ bổ sung comment và minor fixes
//===============================================================

/*----------- 1. Leave Type (Giữ, bổ sung validation) ----------*/
Table absence.leave_type {
  code              varchar(50) [pk]
  name              varchar(100)
  is_paid           boolean [default:true]
  is_quota_based    boolean [default:true]
  requires_approval boolean [default:true]
  
  unit_code         varchar(10)                 // 'HOUR' | 'DAY'
  core_min_unit     decimal(6,2)                // 1.00, 0.50
  
  allows_half_day   boolean [default:false]     // 2025-12-01 NEW
  
  holiday_handling  varchar(30)                 // 'EXCLUDE_HOLIDAYS'|'INCLUDE_HOLIDAYS'
  overlap_policy    varchar(30)                 // 'ALLOW'|'DENY'
  support_scope     varchar(50)                 // 'VN:LE,SG:BU'
  
  // [v5.1] ELIGIBILITY - changed 12dec2025
  // DEPRECATED 30Mar2026 (Change 11): Eligibility centralized at leave_class level only.
  // Removed default_eligibility_profile_id — Core eligibility engine is single source of truth for WHO.
  // Was: default_eligibility_profile_id uuid [null, ref: > eligibility.eligibility_profile.id]
  
  // 30Mar2026 NEW (Change 11): Explicit cancellation deadline — BRD BR-ABS-008, H-P0-001
  cancellation_deadline_days int [default:1]   // Business days before leave start; self-cancel blocked after. Configurable per type/BU.
  
  metadata          jsonb
  is_active         boolean [default:true]
  effective_start   date
  effective_end     date [null]
  
  created_at        timestamptz [default:`now()`] // 2025-12-01 NEW
  updated_at        timestamptz [null]            // 2025-12-01 NEW
  
  Note: 'changed 12dec2025, 30Mar2026. 30Mar2026 (Change 11): Removed eligibility_profile_id (centralized at leave_class). Added cancellation_deadline_days (H-P0-001, BR-ABS-008). VLC refs: Art. 113 (annual 12d), Art. 114 (sick 30-180d), Art. 139 (maternity 6m), Art. 115 (unpaid by agreement).'
}

// 2025-12-01 KEEP: Giữ nguyên thiết kế v4
// ADD: allows_half_day, created_at, updated_at


/*----------- 2. Leave Class (Giữ nguyên v4) -------------------*/
Table absence.leave_class {
  id                uuid [pk]
  type_code         varchar(50) [ref: > absence.leave_type.code]
  code              varchar(50) [unique]
  name              varchar(100)
  status_code       varchar(20) [default: 'ACTIVE']
  
  scope_owner       varchar(10)                 // 'EMP'
  mode_code         varchar(10)                 // 'ACCOUNT'|'LIMIT'|'UNPAID'
  unit_code         varchar(10)                 // 'HOUR'|'DAY'
  
  period_profile    jsonb
  posting_map       jsonb
  
  // [v5.1] ELIGIBILITY - changed 12dec2025
  default_eligibility_profile_id uuid [null, ref: > eligibility.eligibility_profile.id]  // changed 26Mar2026: F1 - corrected schema name from core → eligibility
  
  // DEPRECATED - changed 12dec2025: Use default_eligibility_profile_id instead
  eligibility_json  jsonb  [null]
  
  rules_json        jsonb  [null]
  
  emit_expire_turnover boolean [default:false]
  
  bu_id             uuid [null]
  le_id             uuid [null]
  country_code      varchar(10) [null]
  
  effective_start   date
  effective_end     date [null]
  metadata          jsonb
  
  created_at        timestamptz [default:`now()`] // 2025-12-01 NEW
  updated_at        timestamptz [null]            // 2025-12-01 NEW
  
  Note: 'changed 12dec2025: Added default_eligibility_profile_id. eligibility_json DEPRECATED - use Core.EligibilityProfile for new implementations'
}

// 2025-12-01 KEEP: Giữ nguyên thiết kế v4


/*----------- 2.1 Leave Policy (NEW from Absence v4) ----------*/
// [v5.1] NEW TABLE - changed 12dec2025: Merged from 3.Absence.v4.dbml
Table absence.leave_policy {
  id                uuid [pk]
  type_code         varchar(50) [ref: > absence.leave_type.code]
  code              varchar(50) [unique]
  name              varchar(100)
  
  // [v5.1] ELIGIBILITY - changed 12dec2025
  // DEPRECATED 30Mar2026 (Change 12): Eligibility centralized at leave_class level only.
  // Removed — Core eligibility engine is single source of truth.
  // Was: default_eligibility_profile_id uuid [null, ref: > eligibility.eligibility_profile.id]
  
  // 30Mar2026 NEW (Change 12): FK to leave_class — code hiện tại link class qua policy vẫn hoạt động
  //class_id          uuid [null, ref: > absence.leave_class.id] 

  // ── SCOPE (optional filtering) ──
  country_code      varchar(10) [null]         // null = all countries
  legal_entity_id   uuid [null]                // null = all LEs

  // ── DISCRIMINATOR ──
  policy_type         varchar(50) [not null]     // Phase 1: ACCRUAL|CARRY|LIMIT|VALIDATION|PRORATION|ROUNDING|SENIORITY

    // ── RULE PAYLOAD ──
  // Centralized config in JSONB — schema validated per rule_type at application layer.
  // ACCRUAL:    {method, amount_per_period, frequency, unit, max_balance, tenure_tiers[]}
  // CARRY:      {allow_carry, max_carry_qty, carry_unit, expiry_months_after_year_end, expiry_action}
  // SENIORITY:  {tiers[{min_years, max_years, entitlement_days}], vlc_reference}
  // LIMIT:      {max_per_request, max_per_month, max_per_year, min_notice_days}
  // VALIDATION: {rules[{type, params}]}
  // PRORATION:  {method, basis}
  // ROUNDING:   {method, precision}
  config_json       jsonb [not null]

  // Rule JSONs — DEPRECATED 30Mar2026 (Change 12): Sẽ migrate sang absence.absence_rule + class_rule_assignment.
  // GIỮ columns để tránh lỗi development. Code mới đọc từ absence_rule, code cũ vẫn đọc JSONB.
  accrual_rule_json jsonb  [null]     // DEPRECATED 30Mar2026 → absence_rule(ACCRUAL)
  carry_rule_json   jsonb  [null]     // DEPRECATED 30Mar2026 → absence_rule(CARRY)
  overdraft_allowed boolean [default:false]
  overdraft_limit_hours decimal(6,2) [null]
  metadata          jsonb
  
  check_limit_line  boolean [default:true]
  
  effective_start   date
  effective_end     date [null]
  
  // [v5.1] Additional rules - changed 12dec2025
  limit_rule_json   jsonb  [null]     // DEPRECATED 30Mar2026 → absence_rule(LIMIT)
  validation_json   jsonb  [null]     // DEPRECATED 30Mar2026 → absence_rule(VALIDATION)
  rounding_json     jsonb  [null]     // DEPRECATED 30Mar2026 → absence_rule(ROUNDING)
  proration_json    jsonb  [null]     // DEPRECATED 30Mar2026 → absence_rule(PRORATION)
  
  Note: 'changed 12dec2025, 30Mar2026. 30Mar2026 (Change 12): Removed eligibility_profile_id (centralized at leave_class). Added class_id FK. JSONB rule columns DEPRECATED — will migrate to absence_rule + class_rule_assignment. Columns kept for backward compatibility.'
}

// [v5.1] NEW TABLE - changed 12dec2025: Policy assignment
// DEPRECATED 30Mar2026 (Change 13): Replaced by Core eligibility engine (eligibility.eligibility_profile).
// WHO is eligible for leave is determined by eligibility_profile_id on leave_class.
// This table is redundant — Core module provides centralized O(1) eligibility membership checks.
// Table absence.policy_assignment {
//   id                uuid [pk]
//   policy_id         uuid [ref: > absence.leave_policy.id]
//   assignment_type   varchar(20)                 // EMPLOYEE, BU, LE, GRADE
//   assignment_id     uuid                        // id thực thể
//   effective_start   date
//   effective_end     date [null]
//   
//   Note: 'changed 12dec2025: Merged from 3.Absence.v4.dbml'
// }


/*----------- 3. Leave Instant (Giữ nguyên v4) -----------------*/
Table absence.leave_instant {
  id                uuid [pk]
  employee_id       uuid [ref: > employment.employee.id]
  class_id          uuid [ref: > absence.leave_class.id]
  state_code        varchar(20) [default: 'ACTIVE']
  
  current_qty       decimal(10,2) [default: 0.00]
  hold_qty          decimal(10,2) [default: 0.00]
  available_qty     decimal(10,2) [default: 0.00]
  
  limit_yearly      decimal(10,2) [null]
  limit_monthly     decimal(10,2) [null]
  limit_per_case    decimal(10,2) [null]
  limit_rolling_days int [null]
  used_ytd          decimal(10,2) [default: 0.00]
  used_mtd          decimal(10,2) [default: 0.00]
  
  bu_id             uuid [null]
  le_id             uuid [null]
  country_code      varchar(10) [null]
  
  effective_start   date
  effective_end     date [null]
  metadata          jsonb
  
  created_at        timestamptz [default:`now()`] // 2025-12-01 NEW
  updated_at        timestamptz [null]            // 2025-12-01 NEW
  
  Indexes {
    (employee_id, class_id)
    (state_code)
  }
}


/*----------- 3.1 Leave Instant Detail (NEW from Absence v4) ---*/
// [v5.1] NEW TABLE - changed 12dec2025: Grant/lot tracking with FEFO
Table absence.leave_instant_detail {
  id                uuid [pk]
  instant_id        uuid [ref: > absence.leave_instant.id]
  lot_kind          varchar(20)       // GRANT|CARRY|BONUS|TRANSFER|OTHER
  eff_date          date
  expire_date       date [null]
  lot_qty           decimal(10,2)     // tổng số được cấp cho lot
  used_qty          decimal(10,2) [default: 0.00]
  priority          smallint [default: 100] // FEFO/độ ưu tiên trừ
  tag               varchar(50) [null]
  metadata          jsonb
  
  Indexes { 
    (instant_id, eff_date)
    (instant_id, expire_date) 
  }
  
  Note: 'changed 12dec2025: Merged from 3.Absence.v4.dbml - FEFO engine tracking'
}


/*----------- 3.2 Leave Event Definition (NEW from Absence v4) -*/
// [v5.1] NEW TABLE - changed 12dec2025: Event definitions
Table absence.leave_event_def {
  id                uuid [pk]
  code              varchar(50) [unique]  // ACCRUAL|BOOK_HOLD|START_POST|ADJUST|EXPIRE|CARRY|RESET_LIMIT
  name              varchar(100)
  trigger_kind      varchar(20)           // SCHEDULED|REQUEST_BASED|MANUAL|API
  schedule_expr     varchar(100) [null]   // nếu SCHEDULED (cron/iso)
  policy_refs       jsonb  [null]         // danh sách policy code/ID cần áp dụng
  metadata          jsonb
  is_active         boolean [default:true]
  
  Note: 'changed 12dec2025: Merged from 3.Absence.v4.dbml'
}


// 2025-12-01 KEEP: Giữ nguyên thiết kế v4


/*----------- 4. Leave Movement (Giữ nguyên v4) ----------------*/
Table absence.leave_movement {
  id                uuid [pk]
  instant_id        uuid [ref: > absence.leave_instant.id]
  class_id          uuid [ref: > absence.leave_class.id]
  event_code        varchar(50)
  qty               decimal(10,2)
  unit_code         varchar(10)
  
  period_id         uuid  [null]
  effective_date    date
  expire_date       date [null]
  posted_at         timestamptz [default: `now()`]  // 27Mar2026: changed (Change 10)
  
  request_id        uuid [null]
  lot_id            uuid [null, ref: > absence.leave_instant_detail.id]
  run_id            uuid [null]
  idempotency_key   varchar(120) [null]
  
  bu_id             uuid [null]
  le_id             uuid [null]
  country_code      varchar(10) [null]
  
  metadata          jsonb
  
  Indexes {
    (instant_id, effective_date)
    (class_id, event_code, effective_date)
    (request_id)
    (run_id)
    (idempotency_key)
  }
}

// 2025-12-01 KEEP: Giữ nguyên thiết kế v4 (immutable ledger)


/*----------- 5. Leave Request (Giữ, bổ sung status) -----------*/
Table absence.leave_request {
  id            uuid [pk]
  employee_id   uuid [ref: > employment.employee.id]
  class_id      uuid [ref: > absence.leave_class.id]
  
  start_dt      timestamp
  end_dt        timestamp
  
  total_days    decimal(6,2) [null]             // 2025-12-01 NEW: calculated working days
  
  is_half_day   boolean [default:false]         // 2025-12-01 NEW
  half_day_period varchar(10) [null]            // 2025-12-01 NEW: MORNING, AFTERNOON
  
  qty_hours_req decimal(6,2) [null]
  
  status_code   varchar(20)                     // DRAFT, PENDING, APPROVED, REJECTED, WITHDRAWN, CANCELLED
  // workflow_state jsonb  [null]   // DEPRECATED 27Mar2026 → Temporal workflow engine
  reason        text [null]
  
  instant_id    uuid [null, ref: > absence.leave_instant.id]
  
  submitted_at  timestamptz [null]              // 2025-12-01 NEW; 27Mar2026: changed (Change 10)
  approved_by   uuid [ref: > employment.employee.id, null] // 2025-12-01 NEW
  approved_at   timestamptz [null]              // 2025-12-01 NEW; 27Mar2026: changed (Change 10)
  rejection_reason text [null]                  // 2025-12-01 NEW
  
  // escalation_level smallint [default:0]  // DEPRECATED 27Mar2026 → Temporal workflow engine
  
  metadata      jsonb
  created_at    timestamptz [default:`now()`]
  updated_at    timestamptz [null]                // 2025-12-01 NEW
  
  Indexes {
    (employee_id, status_code)
    (class_id, start_dt)
  }
}

// 2025-12-01 CHANGED:
//   - ADD total_days, is_half_day, half_day_period
//   - ADD submitted_at, approved_by, approved_at, rejection_reason
//   - ADD updated_at


/*----------- 6. Leave Reservation (Giữ nguyên v4) -------------*/
Table absence.leave_reservation {
  request_id     uuid [pk, ref: > absence.leave_request.id]
  instant_id     uuid [ref: > absence.leave_instant.id]
  reserved_qty   decimal(10,2)
  expires_at     timestamptz [null]
  
  created_at     timestamptz [default:`now()`]    // 2025-12-01 NEW
}


/*----------- 6.1 Leave Reservation Line (NEW 30Mar2026, Change 16) */
// FEFO reservation line sub-table — links each reservation to specific leave_instant_detail lots.
// Ensures First-Expired-First-Out consumption tracking with FK integrity.
Table absence.leave_reservation_line {
  id                uuid [pk]
  
  reservation_id    uuid [not null, ref: > absence.leave_reservation.request_id]
  
  // FEFO source tracking — link đến lot/grant cụ thể trong leave_instant_detail
  source_lot_id     uuid [not null, ref: > absence.leave_instant_detail.id]
  
  reserved_amount   decimal(10,2) [not null]
  expiry_date       date [null]                 // copied from lot for quick query
  
  created_at        timestamptz [default:`now()`]
  
  Indexes {
    (reservation_id)
    (source_lot_id)
    (expiry_date)
  }
  
  Note: 'NEW 30Mar2026 (Change 16). FEFO-ordered reservation lines linking to leave_instant_detail lots. Example: Employee has Lot A (3d, expires 2026-03-31) + Lot B (7d, expires 2026-12-31). Reservation for 4d creates: Line 1 → Lot A (3d), Line 2 → Lot B (1d). Benefits: FK integrity, SQL-queryable FEFO, immutable ledger consistency.'
}

