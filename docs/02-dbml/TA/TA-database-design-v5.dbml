//===============================================================
//  NEW TABLES — 27Mar2026 (Changes 6, 8, 9)
//===============================================================

/*----------- Period Management (NEW 27Mar2026, Change 8) -------*/
// Payroll period lifecycle: OPEN → LOCKED → CLOSED
// Cross-module: Used by ta.timesheet_header.period_id FK
Table ta.period {
  id              uuid [pk]
  code            varchar(50) [unique]             // e.g., "2026-03", "2026-Q1-W12"
  name            varchar(100)                     // e.g., "March 2026"
  
  period_type     varchar(20) [default:'MONTHLY']  // See Enum period_type: MONTHLY | CUSTOM
  start_date      date
  end_date        date
  
  status_code     varchar(20) [default:'OPEN']     // See Enum period_status: OPEN | LOCKED | CLOSED
  locked_at       timestamptz [null]               // When period was locked for payroll processing
  locked_by       uuid [ref: > employment.employee.id, null]
  
  metadata        jsonb
  created_at      timestamptz [default:`now()`]
  updated_at      timestamptz [null]
  
  Indexes {
    (start_date, end_date) [unique]
    (status_code)
  }
  
  Note: 'Payroll period lifecycle. OPEN = accepting records/timesheets. LOCKED = frozen for payroll processing. CLOSED = finalized and exported. Used by timesheet_header.period_id.'
}


/*----------- Comp Time Balance (NEW 27Mar2026, Change 6) -------*/
// Compensatory time off balance for employees taking comp-time instead of OT pay
// Cross-module: overtime_request.comp_time_elected → feeds into this balance
Table ta.comp_time_balance {
  id               uuid [pk]
  employee_id      uuid [ref: > employment.employee.id]
  
  earned_hours     decimal(8,4) [default:0]       // Total comp hours earned from approved OT
  used_hours       decimal(8,4) [default:0]       // Total comp hours used (taken as leave)
  available_hours  decimal(8,4) [default:0]       // = earned - used (computed or trigger-maintained)
  
  expiry_date      date [null]                    // When unused comp-time expires
  expiry_action    varchar(20) [null]             // See Enum comp_time_expiry_action: EXTENSION | CASHOUT | FORFEITURE
  
  metadata         jsonb
  created_at       timestamptz [default:`now()`]
  updated_at       timestamptz [null]
  
  Indexes {
    (employee_id) [unique]                        // One balance record per employee
    (expiry_date)                                 // Query soon-to-expire balances
  }
  
  Note: 'Compensatory time off balance. VLC Art. 98: OT comp-time in lieu of payment. Flow: overtime_request(comp_time_elected=true) → approved → earned_hours increments.'
}


/*----------- Termination Balance Record (NEW 27Mar2026, Change 9) */
// Leave balance snapshot at employee termination for compliance and payroll deduction
// Cross-module: Payroll has pay_master.termination_pay_config (AQ-10) for final-pay elements
Table absence.termination_balance_record {
  id                      uuid [pk]
  employee_id             uuid [ref: > employment.employee.id]
  termination_date        date
  
  // Snapshot of all leave balances at termination
  balance_snapshots       jsonb                  // [{leave_type_code, earned, used, reserved, available}]
  
  // Balance disposition
  balance_action          varchar(20) [default:'HR_REVIEW']  // See Enum termination_balance_action: AUTO_DEDUCT | HR_REVIEW | WRITE_OFF | RULE_BASED
  
  // VLC Art. 21: Written consent required before auto-deduction from final pay
  employee_consent_obtained boolean [default:false]  // REQUIRED for AUTO_DEDUCT action
  
  // HR review
  hr_reviewer_id          uuid [ref: > employment.employee.id, null]
  hr_review_notes         text [null]
  reviewed_at             timestamptz [null]
  
  // Payroll integration
  payroll_deduction_amount decimal(15,2) [null]  // Amount sent to Payroll for deduction from final pay
  
  metadata                jsonb
  created_at              timestamptz [default:`now()`]
  updated_at              timestamptz [null]
  
  Indexes {
    (employee_id, termination_date) [unique]     // One record per employee per termination
  }
  
  Note: 'Leave balance snapshot at termination. VLC Art. 21: auto-deduction from final pay requires written employee consent. Cross-module: Payroll pay_master.termination_pay_config handles the payment element.'
}


//===============================================================
//  NEW TABLES — 30Mar2026 (Changes 14, 15, 17)
//  Option C: Centralized Rule Engine + N:N Mapping + Accrual Batch
//===============================================================

/*----------- Absence Rule (NEW 30Mar2026, Change 14) -----------*/
// Centralized rule repository for ALL absence business rules.
// 9 Policy Entities from bounded-contexts.md § 11 → 9 rule_types.
// Phase 1 (Absence): ACCRUAL | CARRY | LIMIT | VALIDATION | PRORATION | ROUNDING | SENIORITY
// Phase 2 (Full TA): + COMP_TIME | OVERTIME | SHIFT_SWAP | BIOMETRIC | HOLIDAY | TERMINATION | APPROVAL
Table absence.absence_rule {
  id                uuid [pk]
  tenant_id         uuid [null]
  
  // ── DISCRIMINATOR ──
  rule_type         varchar(30) [not null]     // Phase 1: ACCRUAL|CARRY|LIMIT|VALIDATION|PRORATION|ROUNDING|SENIORITY
  
  // ── IDENTITY ──
  code              varchar(50) [not null]     // unique per tenant + rule_type
  name              varchar(255) [not null]
  description       text [null]
  
  // ── VERSION & LIFECYCLE ──
  version           int [not null, default: 1] // auto-increment on update
  status_code       varchar(20) [default: 'ACTIVE']  // ACTIVE | INACTIVE | DRAFT
  
  // ── SCOPE (optional filtering) ──
  country_code      varchar(10) [null]         // null = all countries
  legal_entity_id   uuid [null]                // null = all LEs
  
  // ── RULE PAYLOAD ──
  // Centralized config in JSONB — schema validated per rule_type at application layer.
  // ACCRUAL:    {method, amount_per_period, frequency, unit, max_balance, tenure_tiers[]}
  // CARRY:      {allow_carry, max_carry_qty, carry_unit, expiry_months_after_year_end, expiry_action}
  // SENIORITY:  {tiers[{min_years, max_years, entitlement_days}], vlc_reference}
  // LIMIT:      {max_per_request, max_per_month, max_per_year, min_notice_days}
  // VALIDATION: {rules[{type, params}]}
  // PRORATION:  {method, basis}
  // ROUNDING:   {method, precision}
  config_json       jsonb [not null]
  
  // ── AUDIT ──
  effective_start   date [not null]
  effective_end     date [null]
  is_current_flag   boolean [default: true]    // SCD Type 2 — false = historical version
  
  metadata          jsonb
  created_at        timestamptz [default:`now()`]
  updated_at        timestamptz [null]
  created_by        uuid [not null]
  updated_by        uuid [null]
  
  Indexes {
    (tenant_id, rule_type, code, is_current_flag) [unique, name: 'uq_absence_rule_tenant_type_code']
    (tenant_id, rule_type, status_code)
    (rule_type, country_code)
  }
  
  Note: '''
  NEW 30Mar2026 (Change 14). Centralized rule repository — Option C: Rule Engine.
  
  Maps 9 Policy Entities (bounded-contexts.md § 11) to rule_type discriminator:
  1. LeavePolicy → ACCRUAL, CARRY, LIMIT, VALIDATION, PRORATION, ROUNDING, SENIORITY
  2. CompTimePolicy → COMP_TIME (Phase 2)
  3. SickLeavePolicy → SICK_LEAVE (Phase 2)
  4. OvertimePolicy → OVERTIME (Phase 2)
  5. ShiftSwapPolicy → SHIFT_SWAP (Phase 2)
  6. BiometricPolicy → BIOMETRIC (Phase 2)
  7. HolidayPolicy → HOLIDAY (Phase 2)
  8. TerminationPolicy → TERMINATION (Phase 2)
  9. ApprovalChain → APPROVAL (Phase 2)
  
  Benefits vs JSONB-in-policy:
  1. SQL-level batch filtering: WHERE rule_type = 'ACCRUAL' (indexed)
  2. Reusable: 1 rule → N classes via class_rule_assignment (N:N)
  3. Auditable: SCD Type 2 versioning (is_current_flag)
  4. Flexible: config_json keeps JSONB payload per rule_type
  5. Scopable: optional country_code/legal_entity_id filtering
  '''
}


/*----------- Class Rule Assignment (NEW 30Mar2026, Change 15) --*/
// N:N mapping between leave_class and absence_rule.
// leave_class is NOT modified — rules connected via this independent table.
Table absence.class_policy_assignment {
  id                uuid [pk]
  tenant_id         uuid [null]
  
  class_id          uuid [not null, ref: > absence.leave_class.id]
  policy_id           uuid [not null, ref: > absence.leave_policy.id]
  
  // ── ASSIGNMENT METADATA ──
  priority          int [default: 10]          // evaluation order (lower = first)
  is_override       boolean [default: false]   // true = overrides inherited rule
  notes             text [null]                // admin notes
  
  // ── LIFECYCLE ──
  effective_start   date [not null]
  effective_end     date [null]
  is_current_flag   boolean [default: true]
  
  created_at        timestamptz [default:`now()`]
  updated_at        timestamptz [null]
  created_by        uuid [not null]
  
  Indexes {
    (tenant_id, class_id, rule_id, is_current_flag) [unique, name: 'uq_class_rule_assignment']
    (class_id, is_current_flag)
    (rule_id)
  }
  
  Note: '''
  NEW 30Mar2026 (Change 15). N:N mapping: leave_class ↔ absence_rule.
  
  Design:
  1. leave_class NOT modified — rules connect through this table independently
  2. One class → multiple rules of different types (ACCRUAL + CARRY + LIMIT + SENIORITY)
  3. One rule → multiple classes (reuse)
  4. priority for evaluation ordering
  5. is_override for BU/LE-specific overrides without changing base rule
  6. SCD Type 2 history via is_current_flag
  
  Example:
    ANNUAL_STANDARD → [ACCRUAL_MONTHLY, CARRY_5DAYS, LIMIT_STD, SENIORITY_VLC113]
    ANNUAL_SENIOR   → [ACCRUAL_MONTHLY, CARRY_10DAYS, LIMIT_SENIOR, SENIORITY_VLC113]
    (ACCRUAL_MONTHLY and SENIORITY_VLC113 reused across both classes)
  '''
}


/*----------- Leave Accrual Run (NEW 30Mar2026, Change 17) ------*/
// Accrual batch run tracking with idempotency constraint.
// ADR-TA-002: Idempotent monthly accrual. One COMPLETED run per plan per period.
Table absence.leave_accrual_run {
  id                uuid [pk]
  tenant_id         uuid [null]
  
  // ── BATCH IDENTITY ──
  plan_rule_id      uuid [not null, ref: > absence.absence_rule.id]  // ACCRUAL rule that triggered this run
  period_start      date [not null]
  period_end        date [not null]
  
  // ── EXECUTION STATUS ──
  status_code       varchar(20) [not null, default: 'RUNNING']  // RUNNING | COMPLETED | FAILED | SKIPPED
  
  employee_count    int [default: 0]
  movements_created int [default: 0]
  
  started_at        timestamptz [not null]
  completed_at      timestamptz [null]
  failed_at         timestamptz [null]
  failure_reason    text [null]
  
  metadata          jsonb
  created_at        timestamptz [default:`now()`]
  updated_at        timestamptz [null]
  created_by        uuid [not null]
  
  Indexes {
    (tenant_id, plan_rule_id, period_start) [unique, name: 'uq_accrual_run_idempotency']
    (tenant_id, status_code)
    (plan_rule_id)
  }
  
  Note: 'NEW 30Mar2026 (Change 17). ADR-TA-002: Idempotent accrual batch. Unique constraint (plan_rule_id, period_start) prevents duplicate runs. SKIPPED status returned when re-run attempted for same period. Replaces implicit run tracking in leave_movement.run_id.'
}


