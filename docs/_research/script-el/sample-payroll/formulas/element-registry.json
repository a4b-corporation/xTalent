    "elements": [
        {
            "code": "BASE_SALARY",
            "name": "Lương cơ bản hợp đồng",
            "type": "EARNING",
            "subtype": "FIXED",
            "applicability": [
                "OFFICE",
                "DOCTOR",
                "WORKER"
            ],
            "formula": {
                "dsl": "BASE_SALARY",
                "mvel": "employee.salary.baseSalary",
                "description": "Lấy trực tiếp từ hợp đồng lao động — không tính toán"
            },
            "dependencies": [],
            "taxable": true,
            "siContribution": true,
            "effectiveDate": "2024-01-01",
            "executionOrder": 1
        },
        {
            "code": "PRORATED_SALARY",
            "name": "Lương theo ngày công thực tế (Pro-rata)",
            "type": "EARNING",
            "subtype": "COMPUTED",
            "applicability": [
                "OFFICE",
                "DOCTOR"
            ],
            "formula": {
                "dsl": "proRata(BASE_SALARY, actualWorkDays, standardWorkDays)",
                "mvel": "baseSalary * (actualWorkDays / standardWorkDays)",
                "description": "Lương thực nhận sau điều chỉnh số ngày công"
            },
            "dependencies": [
                "BASE_SALARY"
            ],
            "inputs": [
                "actualWorkDays",
                "standardWorkDays"
            ],
            "taxable": true,
            "siContribution": true,
            "effectiveDate": "2024-01-01",
            "executionOrder": 2
        },
        {
            "code": "SENIORITY_ALLOWANCE",
            "name": "Phụ cấp thâm niên",
            "type": "EARNING",
            "subtype": "ALLOWANCE",
            "applicability": [
                "OFFICE",
                "DOCTOR",
                "WORKER"
            ],
            "formula": {
                "dsl": "min(seniorityYears * 0.01, 0.15) * BASE_SALARY",
                "mvel": "Math.min(seniorityYears * 0.01, 0.15) * baseSalary",
                "description": "1% × năm thâm niên × lương cơ bản, tối đa 15%"
            },
            "dependencies": [
                "BASE_SALARY"
            ],
            "inputs": [
                "seniorityYears"
            ],
            "taxable": true,
            "siContribution": true,
            "effectiveDate": "2024-01-01",
            "executionOrder": 3
        },
        {
            "code": "TRANSPORT_ALLOWANCE",
            "name": "Phụ cấp đi lại",
            "type": "EARNING",
