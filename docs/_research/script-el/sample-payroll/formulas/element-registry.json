        },
        {
            "code": "POSITION_ALLOWANCE",
            "name": "Phụ cấp chức vụ",
            "type": "EARNING",
            "subtype": "ALLOWANCE",
            "applicability": [
                "OFFICE",
                "DOCTOR"
            ],
            "formula": {
                "dsl": "lookup(POSITION_ALLOWANCE_TABLE, jobGrade)",
                "mvel": "policyService.getPositionAllowance(employee.jobGrade)",
                "description": "Phụ cấp theo bậc chức vụ"
            },
            "dependencies": [],
            "taxable": true,
            "siContribution": true,
            "executionOrder": 3
        },
        {
            "code": "PERFORMANCE_BONUS",
            "name": "Thưởng KPI (3P — Pay for Performance)",
            "type": "EARNING",
            "subtype": "BONUS",
            "applicability": [
                "OFFICE"
            ],
            "formula": {
                "dsl": "when kpiScore >= 1.2 then BASE_SALARY * 0.2\nwhen kpiScore >= 1.0 then BASE_SALARY * 0.1\nwhen kpiScore >= 0.8 then BASE_SALARY * 0.05\nelse 0",
                "mvel": "kpiScore >= 1.2 ? baseSalary * 0.2 : kpiScore >= 1.0 ? baseSalary * 0.1 : kpiScore >= 0.8 ? baseSalary * 0.05 : 0",
                "description": "KPI bonus theo thang điểm: ≥120% → 20%, ≥100% → 10%, ≥80% → 5%"
            },
            "dependencies": [
                "BASE_SALARY"
            ],
            "inputs": [
                "kpiScore"
            ],
            "taxable": true,
            "siContribution": false,
            "_note": "Thưởng KPI không tính BHXH (không phải quỹ lương thường xuyên)",
            "executionOrder": 4
        },
        {
            "code": "OT_150",
            "name": "Lương OT ngày thường (150%)",
            "type": "EARNING",
            "subtype": "OVERTIME",
            "applicability": [
                "OFFICE",
                "DOCTOR"
            ],
            "formula": {
                "dsl": "(BASE_SALARY / standardWorkDays / 8) * otHours150 * 1.5",
                "mvel": "(baseSalary / standardWorkDays / 8.0) * otHours150 * 1.5",
                "description": "Lương giờ thường × 1.5 × số giờ OT ngày thường"
            },
            "dependencies": [
                "BASE_SALARY"
            ],
            "inputs": [
                "otHours150",
                "standardWorkDays"
            ],
            "taxable": true,
            "siContribution": false,
            "executionOrder": 4
        },
        {
