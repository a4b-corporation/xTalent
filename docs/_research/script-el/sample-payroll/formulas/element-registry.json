            ],
            "formula": {
                "dsl": "730000",
                "mvel": "730000",
                "description": "Flat amount 730k — miễn thuế toàn bộ"
            },
            "dependencies": [],
            "taxable": false,
            "taxExemptCeiling": 730000,
            "siContribution": false,
