            "applicability": [
                "OFFICE"
            ],
            "formula": {
                "dsl": "lookup(ALLOWANCE_CONFIG, 'TRANSPORT_ALLOWANCE', employeeId)",
                "mvel": "policyService.getAllowanceAmount('TRANSPORT_ALLOWANCE', employee.id)",
                "description": "Phụ cấp cố định theo cấp bậc, lấy từ config"
            },
            "dependencies": [],
            "taxable": false,
            "taxExemptCeiling": 1500000,
            "siContribution": false,
            "effectiveDate": "2024-01-01",
            "executionOrder": 3
        },
        {
            "code": "LUNCH_ALLOWANCE",
            "name": "Phụ cấp tiền ăn",
