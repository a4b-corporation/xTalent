        {
            "code": "MEDICAL_PROF_ALLOWANCE",
            "name": "Phụ cấp ưu đãi ngành y",
            "type": "EARNING",
            "subtype": "ALLOWANCE",
            "applicability": [
                "DOCTOR"
            ],
            "formula": {
                "dsl": "lookup(MEDICAL_ALLOWANCE_TABLE, medicalGrade).monthlyAmount",
                "mvel": "policyService.getMedicalAllowance(employee.medicalGradeInfo.gradeCode)",
                "description": "Phụ cấp ngành y theo bậc chuyên môn — miễn toàn bộ thuế TNCN"
            },
            "dependencies": [],
            "inputs": [
                "medicalGrade"
            ],
            "taxable": false,
            "taxExempt": true,
            "taxExemptFull": true,
            "siContribution": false,
            "_legalBasis": "Điều 3.1b Luật Thuế TNCN — phụ cấp theo quy định nhà nước",
            "executionOrder": 3
        },
        {
            "code": "HAZARD_ALLOWANCE",
            "name": "Phụ cấp độc hại (tổng)",
            "type": "EARNING",
            "subtype": "ALLOWANCE",
            "applicability": [
                "DOCTOR"
            ],
            "formula": {
                "dsl": "when hazardLevel == 'A' then BASE_SALARY * 0.10\nwhen hazardLevel == 'B' then BASE_SALARY * 0.20\nwhen hazardLevel == 'C' then BASE_SALARY * 0.30\nelse 0",
                "mvel": "hazardLevel.equals('C') ? baseSalary * 0.30 : hazardLevel.equals('B') ? baseSalary * 0.20 : hazardLevel.equals('A') ? baseSalary * 0.10 : 0",
                "description": "Phụ cấp độc hại theo loại A/B/C — tổng số trước khi phân tách miễn/không miễn thuế"
            },
            "dependencies": [
                "BASE_SALARY"
            ],
            "inputs": [
                "hazardLevel"
            ],
            "taxable": "PARTIAL",
            "_note": "Không tính thẳng vào GROSS. Tách thành HAZARD_TAX_EXEMPT + HAZARD_TAXABLE",
            "executionOrder": 4
        },
        {
            "code": "HAZARD_TAX_EXEMPT",
            "name": "Phụ cấp độc hại — phần miễn thuế",
            "type": "INFORMATION",
            "subtype": "TAX_SPLIT",
            "applicability": [
                "DOCTOR"
            ],
            "formula": {
                "dsl": "min(HAZARD_ALLOWANCE, HAZARD_EXEMPT_CEILING)",
                "mvel": "Math.min(hazardAllowance, policyService.getHazardExemptCeiling())",
                "description": "Phần miễn thuế = min(hazard_total, 3,600,000). Không tính vào TAXABLE_INCOME"
            },
            "dependencies": [
                "HAZARD_ALLOWANCE"
            ],
            "taxable": false,
            "siContribution": false,
            "_legalBasis": "NĐ81/2009-CP + TT20/2023 — mức miễn thuế tối đa 3,600,000 VNĐ/tháng",
            "executionOrder": 5
        },
        {
            "code": "HAZARD_TAXABLE",
            "name": "Phụ cấp độc hại — phần chịu thuế",
            "type": "INFORMATION",
            "subtype": "TAX_SPLIT",
            "applicability": [
                "DOCTOR"
            ],
            "formula": {
                "dsl": "max(0, HAZARD_ALLOWANCE - HAZARD_EXEMPT_CEILING)",
                "mvel": "Math.max(0, hazardAllowance - policyService.getHazardExemptCeiling())",
                "description": "Phần vượt trần miễn thuế → phải cộng vào TAXABLE_INCOME"
            },
            "dependencies": [
                "HAZARD_ALLOWANCE",
                "HAZARD_TAX_EXEMPT"
            ],
            "taxable": true,
            "_note": "EMP-004 (Ung bướu, Loại C): Hazard=9.6M, Miễn=3.6M → Taxable=6.0M ← Case phức tạp",
            "executionOrder": 5
        },
        {
            "code": "DUTY_PAY_FLAT",
            "name": "Phụ cấp trực flat-rate (theo QĐ54/BYT)",
            "type": "EARNING",
            "subtype": "DUTY",
            "applicability": [
                "DOCTOR"
            ],
            "formula": {
                "dsl": "sumElements(dutySchedule, (d) => lookup(DUTY_FLAT_RATE_TABLE, d.type, medicalGrade))",
                "mvel": "attendanceService.getDutyFlatRatePay(employee.id, period, employee.medicalGradeInfo.professionalGrade)",
                "description": "Tổng flat-rate trực × số ca theo loại (Normal/Weekend/Holiday)"
            },
            "dependencies": [],
            "inputs": [
                "dutySchedule",
                "medicalGrade"
            ],
            "taxable": true,
            "siContribution": true,
            "executionOrder": 4
        },
        {
            "code": "DUTY_PAY_OT",
            "name": "Lương OT cộng thêm trong ca trực (Weekend/Holiday)",
            "type": "EARNING",
            "subtype": "OVERTIME",
            "applicability": [
                "DOCTOR"
            ],
            "formula": {
                "dsl": "sumElements(dutySchedule.filter(d => d.additionalOT), (d) => (BASE_SALARY / standardWorkDays / 8) * d.additionalOTHours * d.additionalOTRate)",
                "mvel": "attendanceService.getDutyOTAmount(employee.id, period, baseSalary, standardWorkDays)",
                "description": "OT lương thêm cho ca trực ngày nghỉ/lễ = hourlyRate × OT_hours × multiplier (2.0 hoặc 3.0)"
            },
            "dependencies": [
                "BASE_SALARY"
            ],
            "inputs": [
                "dutySchedule",
                "standardWorkDays"
            ],
            "taxable": true,
            "siContribution": false,
            "_note": "Khác DUTY_PAY_FLAT: đây là phần OT tính thêm ngoài flat-rate",
            "executionOrder": 5
        },
        {
            "code": "PIECE_RATE_SALARY",
            "name": "Lương sản phẩm",
            "type": "EARNING",
            "subtype": "PIECE_RATE",
            "applicability": [
                "WORKER"
            ],
            "formula": {
                "dsl": "qualityPassedQty * lookup(PIECE_RATE_TABLE, productCode)",
                "mvel": "qualityPassedQuantity * policyService.getUnitPrice(productCode)",
                "description": "Lương = số SP đạt chất lượng × đơn giá. SP lỗi không được tính"
            },
            "dependencies": [],
            "inputs": [
                "qualityPassedQuantity",
                "productCode"
            ],
            "taxable": true,
            "siContribution": true,
            "executionOrder": 2
        },
        {
            "code": "QUALITY_BONUS",
            "name": "Thưởng chất lượng sản phẩm",
            "type": "EARNING",
            "subtype": "BONUS",
            "applicability": [
                "WORKER"
            ],
            "formula": {
                "dsl": "when qualityRate >= 0.98 then PIECE_RATE_SALARY * 0.05\nwhen qualityRate >= 0.95 then PIECE_RATE_SALARY * 0.03\nwhen qualityRate < 0.90 then PIECE_RATE_SALARY * (-0.05)\nelse 0",
                "mvel": "qualityRate >= 0.98 ? pieceRateSalary * 0.05 : qualityRate >= 0.95 ? pieceRateSalary * 0.03 : qualityRate < 0.90 ? pieceRateSalary * (-0.05) : 0",
                "description": "Thưởng/phạt chất lượng theo ngưỡng. Tier1=+5%, Tier2=+3%, Penalty<90%=-5%"
            },
            "dependencies": [
                "PIECE_RATE_SALARY"
            ],
            "inputs": [
                "qualityRate"
            ],
            "taxable": true,
            "siContribution": false,
            "executionOrder": 3
        },
        {
            "code": "NIGHT_SHIFT_ALLOWANCE",
            "name": "Phụ cấp ca đêm (30% lương ngày)",
            "type": "EARNING",
            "subtype": "SHIFT_PREMIUM",
            "applicability": [
                "WORKER",
                "DOCTOR"
            ],
            "formula": {
                "dsl": "nightShiftCount * (BASE_SALARY / standardWorkDays) * 0.30",
                "mvel": "nightShiftCount * (baseSalary / standardWorkDays) * 0.30",
                "description": "30% × lương ngày × số ca đêm. Ca đêm xác định theo ĐẦU CA ≥22h từ lịch tháng"
            },
            "dependencies": [
                "BASE_SALARY"
            ],
            "inputs": [
                "nightShiftCount",
                "standardWorkDays"
            ],
            "taxable": true,
            "siContribution": true,
            "_legalBasis": "BLLĐ 2019 Điều 98 — không ít hơn 30% so với ca ngày",
            "executionOrder": 3
        },
        {
            "code": "GROSS_SALARY",
            "name": "Tổng thu nhập trước khấu trừ (Gross)",
            "type": "EARNING",
            "subtype": "AGGREGATE",
            "applicability": [
                "OFFICE",
                "DOCTOR",
                "WORKER"
            ],
            "formula": {
                "OFFICE": {
                    "dsl": "PRORATED_SALARY + SENIORITY_ALLOWANCE + TRANSPORT_ALLOWANCE + LUNCH_ALLOWANCE + PHONE_ALLOWANCE + POSITION_ALLOWANCE + PERFORMANCE_BONUS + OT_150 + OT_200 + OT_300",
                    "mvel": "proratedSalary + seniorityAllowance + transportAllowance + lunchAllowance + phoneAllowance + positionAllowance + performanceBonus + ot150 + ot200 + ot300"
                },
                "DOCTOR": {
                    "dsl": "PRORATED_SALARY + SENIORITY_ALLOWANCE + MEDICAL_PROF_ALLOWANCE + HAZARD_TAX_EXEMPT + HAZARD_TAXABLE + POSITION_ALLOWANCE + DUTY_PAY_FLAT + DUTY_PAY_OT + OT_150 + OT_200 + OT_300",
                    "mvel": "proratedSalary + seniorityAllowance + medicalProfAllowance + hazardTaxExempt + hazardTaxable + positionAllowance + dutyPayFlat + dutyPayOT + ot150 + ot200 + ot300",
                    "_note": "Hazard FULL amount đưa vào GROSS để base tính BHXH — split chỉ ảnh hưởng TAXABLE_INCOME"
                },
                "WORKER": {
                    "dsl": "max(PIECE_RATE_SALARY + QUALITY_BONUS + NIGHT_SHIFT_ALLOWANCE + SENIORITY_ALLOWANCE + OT_200, REGIONAL_MIN_WAGE)",
                    "mvel": "Math.max(pieceRateSalary + qualityBonus + nightShiftAllowance + seniorityAllowance + ot200, policyService.getMinWage('ZONE_1'))",
                    "_note": "FLOOR ENFORCEMENT: Gross ≥ Min Wage Vùng 1 (4,960,000). Áp vào GROSS theo yêu cầu người dùng"
                }
            },
            "dependencies": [
                "PRORATED_SALARY",
                "SENIORITY_ALLOWANCE",
                "PERFORMANCE_BONUS",
                "OT_150",
                "OT_200",
                "OT_300",
                "PIECE_RATE_SALARY",
                "QUALITY_BONUS",
                "NIGHT_SHIFT_ALLOWANCE",
                "MEDICAL_PROF_ALLOWANCE",
                "HAZARD_TAX_EXEMPT",
                "HAZARD_TAXABLE",
                "DUTY_PAY_FLAT",
                "DUTY_PAY_OT"
            ],
            "taxable": "PARTIAL",
            "siContribution": "PARTIAL",
            "executionOrder": 6
        },
        {
            "code": "BHXH_BASE",
