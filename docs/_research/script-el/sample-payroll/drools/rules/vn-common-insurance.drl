// Engine: Drools 8 — xTalent HCM Payroll Engine
// Phiên bản: 1.0 | Ngày: 2025-03-04
// Áp dụng: TẤT CẢ loại hình nhân viên VN (OFFICE, DOCTOR, WORKER)
// Tham chiếu: Luật BHXH 2014, Nghị định 73/2024/NĐ-CP
// ============================================================

package vn.xtalent.payroll.rules.vn.common;

import vn.xtalent.payroll.model.*;
import vn.xtalent.payroll.functions.BuiltinFunctions;
import java.math.BigDecimal;

// ─────────────────────────────────────────────────────────
// RULE: Validate BHXH Eligibility
// Mục đích: Kiểm tra điều kiện đóng BHXH trước khi tính
// Salience: 200 (chạy trước mọi BHXH rules)
// ─────────────────────────────────────────────────────────
rule "VN_SI_001 — Check BHXH Eligibility"
    agenda-group "pre-payroll-validation"
    salience 200
    when
        $emp: Employee(
            status == "ACTIVE",
            contractType != "PROBATION",
            contractType != "FREELANCE"
        )
        not PayrollFlag(employeeId == $emp.employeeId, flagCode == "BHXH_INELIGIBLE")
    then
        insert(new PayrollFlag($emp.employeeId, "BHXH_ELIGIBLE", "Đủ điều kiện đóng BHXH"));
        System.out.println("[BHXH] Employee " + $emp.employeeId + " BHXH eligible ✓");
end

// ─────────────────────────────────────────────────────────
// RULE: Calculate BHXH_BASE
// Mục đích: Tính cơ sở đóng BHXH = min(grossSalary, ceiling)
// Phụ thuộc: GROSS_SALARY phải được insert trước
// ─────────────────────────────────────────────────────────
rule "VN_SI_002 — Calculate BHXH Base"
    agenda-group "insurance"
    salience 100
    when
        $emp: Employee(status == "ACTIVE")
        PayrollFlag(employeeId == $emp.employeeId, flagCode == "BHXH_ELIGIBLE")
        $gross: PayrollElement(
            code == "GROSS_SALARY",
            employeeId == $emp.employeeId
        )
        $policy: PolicyConfig(code == "BHXH_CEILING", countryCode == "VN")
        not PayrollElement(code == "BHXH_BASE", employeeId == $emp.employeeId)
    then
        BigDecimal bhxhBase = $gross.getValue().min($policy.getDecimalValue());
        PayrollElement element = new PayrollElement(
            "BHXH_BASE", $emp.employeeId, bhxhBase,
            "min(GROSS_SALARY, BHXH_CEILING)",
            7  // executionOrder
        );
        element.addInput("grossSalary", $gross.getValue());
        element.addInput("bhxhCeiling", $policy.getDecimalValue());
        insert(element);
        // EMP-004: min(60,636,498, 46,800,000) = 46,800,000 (capped!)
        System.out.println("[BHXH_BASE] " + $emp.employeeId + " = " + bhxhBase);
end

// ─────────────────────────────────────────────────────────
// RULE: Calculate BHXH_EMPLOYEE (8%)
// ─────────────────────────────────────────────────────────
rule "VN_SI_003 — Calculate BHXH Employee 8%"
    agenda-group "insurance"
    salience 90
    when
        $emp: Employee(status == "ACTIVE")
        PayrollFlag(employeeId == $emp.employeeId, flagCode == "BHXH_ELIGIBLE")
        $base: PayrollElement(code == "BHXH_BASE", employeeId == $emp.employeeId)
        not PayrollElement(code == "BHXH_EMPLOYEE", employeeId == $emp.employeeId)
    then
        BigDecimal value = $base.getValue().multiply(new BigDecimal("0.08"));
        insert(new PayrollElement("BHXH_EMPLOYEE", $emp.employeeId, value, "BHXH_BASE * 0.08", 8));
        System.out.println("[BHXH_EMP] " + $emp.employeeId + " = " + value);
end

